                        },
                        "card": {
                          "entity": "",
                          "content": "<div class=\"flex flex-col\">\n  <!-- 标题区域 - 增大一个号 -->\n  <h1 class=\"text-3xl font-bold text-left mb-0 m-0\">ADM版本</h1>\n  \n  <!-- ADM补丁内容区域 -->\n  <div class=\"patch-container\">\n    {% set cards = state_attr('sensor.patch_channel_patch_info', 'cards') %}\n    {% if cards %}\n      {% for card in cards %}\n        {% if card.type == 'markdown' %}\n          {% if not loop.first %}\n            <!-- 分隔线 - 模拟markdown --- 样式 -->\n            <hr class=\"border-0 h-px mb-0 my-4 mx-0\">\n          {% endif %}\n          <div class=\"prose max-w-none text-left mb-4 leading-relaxed break-all whitespace-pre-line\">\n            {{ card.content | safe }}\n          </div>\n        {% elif card.type == 'iframe' %}\n          <div class=\"mb-4 rounded-xl overflow-hidden\">\n            <iframe \n              src=\"{{ card.url }}\" \n              class=\"w-full aspect-video min-h-[200px] max-h-[400px] border-0 rounded-xl\"\n              frameborder=\"0\"\n              allowfullscreen>\n            </iframe>\n          </div>\n        {% elif card.type == 'picture' %}\n          <div class=\"text-center my-2 w-full relative z-[1]\">\n            <a href=\"{{ card.tap_action.url_path or '#' }}\" \n               target=\"_blank\" \n               class=\"block w-full relative z-[999] no-underline hover:opacity-80 transition-opacity duration-200\"\n               onclick=\"event.stopPropagation(); window.open('{{ card.tap_action.url_path or '#' }}', '_blank'); return false;\">\n              <img src=\"{{ card.image }}\" \n                   alt=\"ADM补丁图片\"\n                   class=\"w-full h-auto {% if card.tap_action.url_path == card.image %}border-0{% else %}border-2 border-blue-500{% endif %} rounded-lg shadow-sm cursor-pointer block relative z-[999] transition-opacity duration-200\">\n            </a>\n          </div>\n        {% endif %}\n      {% endfor %}\n    {% else %}\n      <!-- 如果没有cards属性，回退到原来的content显示方式 -->\n      <div class=\"prose max-w-none text-left mb-4 leading-relaxed break-all whitespace-pre-line\">\n        {{ state_attr('sensor.patch_channel_patch_info', 'content') | safe }}\n      </div>\n    {% endif %}\n  </div>\n  \n  <!-- 最后的分隔线 - 增大间距 -->\n  <hr class=\"border-0 h-px mb-6 mx-0\" />\n  \n  <!-- 底部链接图标 -->\n  <div class=\"text-center -mt-2\">\n    <a href=\"https://asadedicatedmanager.eu/\" \n       target=\"_blank\" \n       class=\"inline-block mr-2\">\n      <img src=\"https://hass.whiterober.com/api/image/serve/be9c76caf30ba121c1438e870f86e5f1/original?authSig=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkZTIwMjk0ZTE3Yzk0ZDEzYWI2ODhmNDZmYTQyODI4OCIsInBhdGgiOiIvYXBpL2ltYWdlL3NlcnZlL2JlOWM3NmNhZjMwYmExMjFjMTQzOGU4NzBmODZlNWYxL29yaWdpbmFsIiwicGFyYW1zIjpbXSwiaWF0IjoxNzU0MjI1MjkwLCJleHAiOjE3NTQzMTE2OTB9.vzltpTF55BUc71v4LzcpV0qo-ZqAZZSBJhHu0iLHJS4\"\n           width=\"48\" \n           height=\"48\" \n           class=\"align-middle\">\n    </a>\n    <a href=\"https://discord.com/channels/1219676794840547388/1239938054328684657\" \n       target=\"_blank\" \n       class=\"inline-block\">\n      <img src=\"https://hass.whiterober.com/api/image/serve/eb8b3e2a26a52264933c6275fc5bd419/original?authSig=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkZTIwMjk0ZTE3Yzk0ZDEzYWI2ODhmNDZmYTQyODI4OCIsInBhdGgiOiIvYXBpL2ltYWdlL3NlcnZlL2ViOGIzZTJhMjZhNTIyNjQ5MzNjNjI3NWZjNWJkNDE5L29yaWdpbmFsIiwicGFyYW1zIjpbXSwiaWF0IjoxNzU0MjI1MjMwLCJleHAiOjE3NTQzMTE2MzB9.nxJLBE_sHBA30KbHNBCzILcYtWVbD4HPMKNpI9rWYsQ\"\n           width=\"48\" \n           height=\"48\" \n           class=\"align-middle\">\n    </a>\n  </div>\n</div>\n",
                          "ignore_line_breaks": true,
                          "always_update": false,
                          "parse_jinja": true,
                          "code_editor": "Ace",
                          "entities": [],
                          "bindings": [],
