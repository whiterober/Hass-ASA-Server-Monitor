                },
                {
                  "type": "vertical-stack",
                  "cards": [
                    {
                      "type": "conditional",
                      "conditions": [
                        {
                          "entity": "input_select.selected_server",
                          "state_not": ""
                        }
                      ],
                      "card": {
                        "type": "custom:button-card",
                        "show_icon": false,
                        "tap_action": {
                          "action": "navigate",
                          "navigation_path": "/lovelace/asa-server-ops"
                        },
                        "custom_fields": {
                          "arrow": "[[[\n  return `<ha-icon icon=\"mdi:cog\" style=\"\n    color: var(--text-primary-color);\n    --mdc-icon-size: 20px;\n    position: absolute;\n    bottom: 15px;\n    left: 50%;\n    transform: translateX(-50%);\n    z-index: 30;\n  \"></ha-icon>`;\n]]]\n"
                        },
                        "styles": {
                          "card": [
                            {
                              "aspect-ratio": "2.5/1"
                            },
                            {
                              "position": "relative"
                            },
                            {
                              "background": "[[[\n  const server_id = states['input_select.selected_server'].state;\n  const themes = states['sensor.asa_server_themes']?.attributes?.server_themes || {};\n  return themes[server_id]?.bg_image || 'var(--primary-color)';\n]]]\n"
                            },
                            {
                              "background-size": "cover"
                            },
                            {
                              "background-position": "top"
                            },
                            {
                              "background-repeat": "no-repeat"
                            },
                            {
                              "padding": "0px"
                            }
                          ],
                          "custom_fields": {
                            "arrow": [
                              {
                                "position": "absolute"
                              },
                              {
                                "bottom": "5px"
                              },
                              {
                                "left": "0px"
                              },
                              {
                                "width": "100%"
                              },
                              {
                                "height": "100%"
                              },
                              {
                                "pointer-events": "none"
                              }
                            ]
                          }
                        },
                        "card_mod": {
                          "style": "ha-card::after {\n  content: '';\n  position: absolute;\n  bottom: 0;\n  left: 50%;\n  transform: translateX(-50%);\n  width: 60px;\n  height: 60px;\n  {% set server_id = states('input_select.selected_server') %}\n  {% set themes = state_attr('sensor.asa_server_themes', 'server_themes') or {} %}\n  {% set theme = themes.get(server_id, {}) %}\n  {% set overlay = theme.get('overlay_color', 'rgba(var(--rgb-primary-color), 0.7)') %}\n  {% set color_match = overlay | regex_findall_index('rgba?\\(([^)]+)\\)') %}\n  {% if color_match %}\n    {% set rgb = color_match.split(',')[:3] | join(',') %}\n    background: rgba({{ rgb }}, 0.2);\n  {% else %}\n    background: rgba(var(--rgb-primary-color), 0.2);\n  {% endif %}\n  border-radius: 50% 50% 0 0;\n  pointer-events: none;\n  z-index: 5;\n  transition: background 0.3s ease;\n}\nha-card:hover::after {\n  {% set server_id = states('input_select.selected_server') %}\n  {% set themes = state_attr('sensor.asa_server_themes', 'server_themes') or {} %}\n  {% set theme = themes.get(server_id, {}) %}\n  {% set overlay = theme.get('overlay_color', 'rgba(var(--rgb-primary-color), 0.7)') %}\n  {% set color_match = overlay | regex_findall_index('rgba?\\(([^)]+)\\)') %}\n  {% if color_match %}\n    {% set rgb = color_match.split(',')[:3] | join(',') %}\n    background: rgba({{ rgb }}, 0.7) !important;\n  {% else %}\n    background: rgba(var(--rgb-primary-color), 0.7) !important;\n  {% endif %}\n}\n"
                        }
                      }
                    },
                    {
                      "type": "markdown",
                      "content": "---",
                      "text_only": true,
                      "card_mod": {
                        "style": "ha-card {\n  backdrop-filter: none !important;\n  -webkit-backdrop-filter: none !important;\n  background: rgba(0,0,0,0);    # 可选，设为透明 \n}\n"
                      }
                    },
                    {
                      "type": "horizontal-stack",
                      "cards": [
                        {
                          "type": "tile",
                          "entity": "sensor.dialog_server_version",
                          "name": "服务器规则",
                          "icon": "mdi:note",
                          "color": "primary",
                          "hide_state": true,
                          "vertical": false,
                          "tap_action": {
                            "action": "navigate",
                            "navigation_path": "/lovelace/asa-server-rules"
                          },
                          "features_position": "bottom"
                        }
                      ]
                    },
                    {
                      "type": "markdown",
                      "content": "---",
                      "text_only": true,
                      "card_mod": {
                        "style": "ha-card {\n  backdrop-filter: none !important;\n  -webkit-backdrop-filter: none !important;\n  background: rgba(0,0,0,0);    # 可选，设为透明 \n}\n"
                      }
                    },
                    {
                      "type": "horizontal-stack",
                      "cards": [
                        {
                          "type": "custom:button-card",
                          "entity": "input_button.select_server_isl",
                          "name": "[[[\n  const server_data = states['sensor.asa_server_details'];\n  const server = server_data?.attributes?.servers?.find(s => s.ProfileName === 'Isl');\n  const version = server?.ServerVersion !== 'N/A' ? server?.ServerVersion.match(/(\\d+\\.?\\d*)/)?.[1] || 'N/A' : 'N/A';\n  \n  // 端口号获取\n  const ports = server_data?.attributes?.profile_ports || {};\n  const port = ports['Isl'] || '';\n  \n  // 提取服务器版本号\n  const serverVersionMatch = server?.ServerVersion?.match(/(\\d+\\.?\\d*)/);\n  const serverVersion = serverVersionMatch ? serverVersionMatch[1] : null;\n  \n  // 提取官方版本号\n  const officialVersionMatch = server?.OfficialServerVersion?.match(/v(\\d+\\.?\\d*)/);\n  const officialVersion = officialVersionMatch ? officialVersionMatch[1] : null;\n  \n  const needsUpdate = serverVersion && \n                     officialVersion && \n                     serverVersion !== officialVersion;    \n  return `<b>孤岛</b><br><small>${version}${needsUpdate ? ' <span style=\"color: #FF5722;\">🔺</span>' : ''}</small>`;\n]]]\n",
                          "icon": "[[[\n  const themes = states['sensor.asa_server_themes']?.attributes?.server_themes || {};\n  return themes['Isl']?.icon || 'mdi:island';\n]]]\n",
                          "styles": {
                            "icon": [
                              {
                                "color": "[[[\n  const server = states['sensor.asa_server_details']?.attributes?.servers?.find(s => s.ProfileName === 'Isl');\n  const selected_server = states['input_select.selected_server'].state;\n  const themes = states['sensor.asa_server_themes']?.attributes?.server_themes || {};\n  const theme = themes[selected_server] || {};\n  \n  if (server?.Status === 'Running') {\n    return selected_server === 'Isl' ? theme.light_color || '#81C784' : themes['Isl']?.primary_color || '#4CAF50';\n  }\n  return '#9E9E9E';\n]]]\n"
                              }
                            ],
                            "name": [
