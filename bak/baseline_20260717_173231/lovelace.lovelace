div class=\"materials-box\">\n                  <div class=\"materials-box-inner\">\n                    <div class=\"device-icon-wrapper\">\n                      <img class=\"icon-mask-30\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1737960695767-c3c2faaf-e00d-4362-9051-2afae9b11df5.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Industrial Cooker\" />\n                    </div>\n                    <div class=\"v-divider\"></div>\n                    <div class=\"box-right-column\">\n                      <div class=\"tag-icons tag-icons-vertical\">\n                        <svg t=\"1769008871160\" class=\"icon icon-mask-15\" viewBox=\"0 0 1024 1024\" version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\" p-id=\"13760\">\n                          <path d=\"M788.48 410.112h-112.128c-24.064 0-92.16 11.776-115.2-2.56-4.608-16.384 10.24-46.08 14.336-60.416 11.776-41.472 23.04-82.432 34.816-124.416L660.48 41.984c6.656-23.552-24.064-33.792-36.864-15.872L218.112 582.656c-9.216 12.8 3.584 30.72 17.92 30.72h164.352c11.264 0 54.784-7.168 61.952 3.584 6.656 8.704-6.144 35.84-8.704 45.568-30.72 106.496-60.416 212.992-90.112 319.488-6.656 23.552 24.064 33.792 36.864 15.872l404.992-556.544c9.728-13.312-2.56-31.232-16.896-31.232z\" fill=\"#f9f352\" p-id=\"13761\"></path>\n                        </svg>\n                        <svg t=\"1769138787866\" class=\"icon icon-mask-15\" viewBox=\"0 0 1024 1024\" version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\" p-id=\"23855\">\n                          <path d=\"M505.668923 74.919385c-17.142154 19.282708-34.282338 44.994954-100.688738 149.962831-32.143754 53.5552-59.984738 102.829292-85.698954 152.103385-49.274092 96.407631-98.548185 227.089723-98.548185 310.636308 2.140554 72.847754 29.993354 134.973046 85.698954 186.387692C364.266338 925.426215 430.682585 951.138462 509.950031 951.138462s147.822277-25.712246 203.52-79.267446c57.844185-53.565046 85.698954-115.688369 83.5584-188.526277C797.026462 462.684554 503.518523 72