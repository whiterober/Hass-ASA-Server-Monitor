            />\n            </label>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td\n            class=\"border border-gray-300 p-2 text-left align-top\"\n          >\n            巨鱼深水基地<br />\n            <div class=\"flex flex-wrap gap-1 items-start\">\n              <img\n                src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n              />\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n        </tr>\n\n        <tr>\n          <td\n            class=\"sticky left-0 z-10 border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            <label class=\"row-head\" title=\"切换：隐藏本行为空的整列\">\n              <input id=\"row-t-8\" type=\"checkbox\" class=\"row-toggle\" hidden />\n              <img\n                src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n              />\n            </label>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td\n            class=\"border border-gray-300 p-2 text-left align-top\"\n          >\n            蛋糕岛<br />\n            <div class=\"flex flex-wrap gap-1 items-start\">\n              <img\n                src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n              />\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n        </tr>\n\n        <tr>\n          <td\n            class=\"sticky left-0 z-10 border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            <label class=\"row-head\" title=\"切换：隐藏本行为空的整列\">\n              <input id=\"row-t-10\" type=\"checkbox\" class=\"row-toggle\" hidden />\n              <img\n                src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n              />\n            </label>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td\n            class=\"border border-gray-300 p-2 text-left align-top\"\n          >\n            蛋糕岛<br />\n            <div class=\"flex flex-wrap gap-1 items-start\">\n              <div class=\"flex flex-col items-start\">\n                <img\n                  src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n                />\n                <span class=\"badge badge-sm badge-warning mt-1\">×4</span>\n              </div>\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n        </tr>\n\n        <tr>\n          <td\n            class=\"sticky left-0 z-10 border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            <label class=\"row-head\" title=\"切换：隐藏本行为空的整列\">\n              <input id=\"row-t-11\" type=\"checkbox\" class=\"row-toggle\" hidden />\n              <img\n                src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n              />\n            </label>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td\n            class=\"border border-gray-300 p-2 text-left align-top\"\n          >\n            蛋糕岛<br />\n            <div class=\"flex flex-wrap gap-1 items-start\">\n              <div class=\"flex flex-col items-start\">\n                <img\n                  src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n                />\n                <span class=\"badge badge-sm badge-warning mt-1\">×2</span>\n              </div>\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n        </tr>\n\n        <tr>\n          <td\n            class=\"sticky left-0 z-10 border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            <label class=\"row-head\" title=\"切换：隐藏本行为空的整列\">\n              <input id=\"row-t-11-fix\" type=\"checkbox\" class=\"row-toggle\" hidden />\n              <img\n                src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n              />\n            </label>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td\n            class=\"border border-gray-300 p-2 text-left align-top\"\n          >\n            中央车站<br />\n            <div class=\"flex flex-wrap gap-1 items-start\">\n              <img\n                src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n              />\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n        </tr>\n\n        <tr>\n          <td\n            class=\"sticky left-0 z-10 border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            <label class=\"row-head\" title=\"切换：隐藏本行为空的整列\">\n              <input id=\"row-t-12\" type=\"checkbox\" class=\"row-toggle\" hidden />\n              <img\n                src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n              />\n            </label>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\"></td>\n          <td\n            class=\"border border-gray-300 p-2 text-left align-top\"\n          >\n            嘎查乐园<br />\n            <div class=\"flex flex-wrap gap-1 items-start\">\n              <div class=\"flex flex-col items-start\">\n                <img\n                  src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\"\n                />\n                <span class=\"badge badge-sm badge-warning mt-1\">×6</span>\n              </div>\n            </div>\n          </td>\n        </tr>\n      </tbody>\n    </table>\n\n    \n  </div>\n</div>\n",
                          "ignore_line_breaks": true,
                          "always_update": false,
                          "parse_jinja": true,
                          "code_editor": "Ace",
                          "entities": [],
                          "bindings": [],
                          "actions": [],
                          "debounceChangePeriod": 100,
                          "plugins": {
                            "daisyui": {
                              "enabled": true,
                              "url": "https://cdn.jsdelivr.net/npm/daisyui@latest/dist/full.css",
                              "theme": "dark - dark",
                              "overrideCardBackground": false
                            },
                            "tailwindElements": {
                              "enabled": false
                            }
                          },
                          "type": "custom:tailwindcss-template-card",
                          "card_mod": {
                            "style": "ha-card {\n  box-shadow: none !important;\n  padding: 0px !important;\n  font-size: var(--paper-font-body1_-_font-size, 14px) !important;\n  font-family: var(--paper-font-body1_-_font-family, 'Roboto', sans-serif) !important;\n}\n\nha-card table {\n  border-collapse: collapse !important;\n  table-layout: fixed !important;\n}\n\nha-card th, ha-card td {\n  padding: 8px !important;\n  overflow: hidden !important;\n  text-overflow: ellipsis !important;\n}\n\nha-card .sticky {\n  position: sticky !important;\n}\n\nha-card thead th {\n  z-index: 20 !important;\n  border-top: 0 !important; /* 从内联迁移 */\n}\n/* 左上角\"补给品\"单元格需要最高z-index，因为它同时具有横向和纵向sticky */ ha-card thead th:first-child {\n  z-index: 30 !important;\n}\nha-card tbody td:first-child {\n  z-index: 10 !important;\n}\n\nha-card h2 {\n  font-family: inherit !important;\n  font-weight: bold !important;\n  margin: 0 0 16px 0 !important;\n  color: var(--primary-text-color) !important;\n  line-height: 1.3 !important;\n}\n\n/* 确保图片不会被压缩 */\nha-card img {\n  flex-shrink: 0 !important;\n}\n\nha-card .border {\n  border-width: 0px 1px 1px 0px !important;\n  border-color: var(--app-theme-color) !important;\n}\n\n/* 为有内容的单元格提供足够的行高 */\nha-card tbody td {\n  line-height: 1.4 !important;\n  vertical-align: top !important;\n  font-size: var(--paper-font-body1_-_font-size, 12px) !important;\n}\n\n/* 隔列背景色 - 从第2列开始，奇数列为透明，偶数列为次要背景色 */\nha-card tbody td:nth-child(2n) {\n  background-color: transparent !important;\n}\n\nha-card tbody td:nth-child(2n+1):not(:first-child) {\n  background-color: var(--primary-background-color, #f5f5f5) !important;\n}\n\nha-card .borderr {\n  border-top-left-radius: 8px !important;\n  border-top-right-radius: 8px !important;\n  border-bottom-left-radius: var(--ha-card-border-radius, 12px) !important;\n  border-bottom-right-radius: var(--ha-card-border-radius, 12px) !important;\n  height: var(--collect-table-height, 82vh) !important;\n}\n\n/* —— 新增：首列统一用 card_mod 控制宽度/背景/居中 —— */\nha-card thead th:first-child,\nha-card tbody td:first-child {\n  width: 60px !important;\n  min-width: 60px !important;\n  background-color: var(--secondary-background-color, #f5f5f5) !important;\n  text-align: center !important; /* 图标水平居中 */\n}\n\n/* 首列图标块级 + 自动左右外边距，确保水平居中，并由 card_mod 统一尺寸 */\nha-card tbody td:first-child img {\n  display: block !important;\n  margin-left: auto !important;\n  margin-right: auto !important;\n  width: 40px !important;\n  height: 40px !important;\n}\n\n/* 其他列的图片统一尺寸 */\nha-card tbody td:not(:first-child) img {\n  width: 30px !important;\n  height: 30px !important;\n}\n\n/* 统一：非首列列宽与换行，由 card_mod 接管 */\nha-card thead th:nth-child(n+2),\nha-card tbody td:nth-child(n+2) {\n  width: 120px !important;\n  min-width: 120px !important;\n  white-space: normal !important;\n}\n\n/* 表头配色（第2-6列） */\nha-card thead th:nth-child(2) {\n  background-color: #4CAF50 !important;\n  color: #ffffff !important;\n}\nha-card thead th:nth-child(3) {\n  background-color: #009688 !important;\n  color: #ffffff !important;\n}\nha-card thead th:nth-child(4) {\n  background-color: #FF5722 !important;\n  color: #ffffff !important;\n}\nha-card thead th:nth-child(5) {\n  background-color: #9C27B0 !important;\n  color: #ffffff !important;\n}\nha-card thead th:nth-child(6) {\n  background-color: #00BCD4 !important;\n  color: #ffffff !important;\n}\n\n/* 交互：纯 CSS 行/列筛选 + 选中高亮（移自内联） */\n/* 点击区域与高亮 */\nha-card #supply-table thead th label.col-head {\n  display: flex; \n  width: 100%; \n  height: 100%; \n  gap: .25rem; \n  align-items: center; \n  justify-content: center; \n  cursor: pointer; \n  user-select: none;\n  position: absolute;\n  top: 0;\n  left: 0;\n  padding: 8px;\n  z-index: 21;\n}\n/* 确保列首单元格有相对定位，以便label能正确覆盖整个单元格 */ ha-card #supply-table thead th {\n  position: relative;\n}\n/* 确保纵向滚动时列首保持固定 */ ha-card #supply-table thead {\n  position: sticky !important;\n  top: 0 !important;\n  z-index: 20 !important;\n}\n/* 左上角单元格的label需要稍低的z-index，不能超过单元格本身 */ ha-card #supply-table thead th:first-child label {\n  z-index: 29 !important;\n}\n/* 移除可能的焦点描边 */\nha-card #supply-table thead th,\nha-card #supply-table thead th *,\nha-card #supply-table tbody td:first-child,\nha-card #supply-table tbody td:first-child * {\n  outline: none !important; box-shadow: none !important;\n}\n/* 表头不再描边，改为整列/整行背景高亮（见下） */\n/* 行首单元格：保持横向滚动时固定，支持内部绝对定位元素 */ ha-card #supply-table tbody td:first-child { \n  position: sticky !important; \n  left: 0 !important; \n  z-index: 10 !important;\n}\n/* 行首label覆盖整个单元格以接管点击 */ ha-card #supply-table tbody td:first-child .row-head { \n  display: flex;\n  align-items: center;\n  justify-content: center;\n  width: 100%;\n  height: 100%;\n  cursor: pointer;\n  position: absolute;\n  top: 0;\n  left: 0;\n  z-index: 20;\n  padding: 8px;\n}\n/* 确保图片不拦截点击事件，让点击穿透到label */  ha-card #supply-table tbody td:first-child .row-head img {\n  pointer-events: none;\n}\n/* 确保列首图标不拦截点击事件，让点击穿透到label */ ha-card #supply-table thead th .col-head ha-icon {\n  pointer-events: none;\n}\n/* 去除行选中的描边，统一用背景高亮表示选中 */\n\n/* 判空：无任何子元素（仅空白也算空）；或显式 .is-empty */\n/* 仅允许\"最后被选中的一项\"生效；行优先于列（如果选中了行，则列的规则失效） */\n\n/* 行高亮（任意选中的行都高亮，但行首单元格保持原背景色） */\nha-card #supply-table tbody > tr:has(> td:first-child .row-toggle:checked) > td:not(:first-child) {\n  background-color: var(--collect-sel-bg, rgba(3, 169, 244, .15)) !important;\n}\n\n/* 列高亮（只影响tbody中的单元格，保持列首背景色不变） */\n\nha-card #supply-table:has(thead > tr > th:nth-child(2) .col-toggle:checked) tbody td:nth-child(2) { background-color: var(--collect-sel-bg, rgba(3, 169, 244, .15)) !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(3) .col-toggle:checked) tbody td:nth-child(3) { background-color: var(--collect-sel-bg, rgba(3, 169, 244, .15)) !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(4) .col-toggle:checked) tbody td:nth-child(4) { background-color: var(--collect-sel-bg, rgba(3, 169, 244, .15)) !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(5) .col-toggle:checked) tbody td:nth-child(5) { background-color: var(--collect-sel-bg, rgba(3, 169, 244, .15)) !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(6) .col-toggle:checked) tbody td:nth-child(6) { background-color: var(--collect-sel-bg, rgba(3, 169, 244, .15)) !important; }\n\n/* 列首开关：隐藏该列中“空”的整行（放宽条件，优先确保可用性） */\nha-card #supply-table:has(thead > tr > th:nth-child(2) .col-toggle:checked) tbody > tr:has(> td:nth-child(2):not(:has(*))) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(2) .col-toggle:checked) tbody > tr:has(> td:nth-child(2):empty) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(2) .col-toggle:checked) tbody > tr:has(> td:nth-child(2).is-empty) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(3) .col-toggle:checked) tbody > tr:has(> td:nth-child(3):not(:has(*))) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(3) .col-toggle:checked) tbody > tr:has(> td:nth-child(3):empty) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(3) .col-toggle:checked) tbody > tr:has(> td:nth-child(3).is-empty) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(4) .col-toggle:checked) tbody > tr:has(> td:nth-child(4):not(:has(*))) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(4) .col-toggle:checked) tbody > tr:has(> td:nth-child(4):empty) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(4) .col-toggle:checked) tbody > tr:has(> td:nth-child(4).is-empty) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(5) .col-toggle:checked) tbody > tr:has(> td:nth-child(5):not(:has(*))) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(5) .col-toggle:checked) tbody > tr:has(> td:nth-child(5):empty) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(5) .col-toggle:checked) tbody > tr:has(> td:nth-child(5).is-empty) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(6) .col-toggle:checked) tbody > tr:has(> td:nth-child(6):not(:has(*))) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(6) .col-toggle:checked) tbody > tr:has(> td:nth-child(6):empty) { display: none !important; }\nha-card #supply-table:has(thead > tr > th:nth-child(6) .col-toggle:checked) tbody > tr:has(> td:nth-child(6).is-empty) { display: none !important; }\n"
                          }
                        }
                      },
                      "grid_options": {
                        "columns": 24,
                        "rows": "auto"
                      }
                    },
                    {
                      "type": "conditional",
                      "conditions": [
                        {
                          "condition": "state",
                          "entity": "input_select.info_tribe_tab",
                          "state": "采集速查"
                        }
                      ],
                      "card": {
                        "type": "custom:mod-card",
                        "card_mod": {
                          "style": "ha-card {\n  box-shadow: none !important;\n}\n"
                        },
                        "card": {
                          "entity": "",
                          "content": "<div class=\"flex flex-col\">\n  <div class=\"borderr relative overflow-auto border border-gray-300\">\n    <table class=\"table-fixed border-collapse w-full min-w-max\">\n      <thead class=\"sticky top-0 z-20\">\n        <tr>\n          <th class=\"border border-gray-300 p-2 text-center whitespace-nowrap\">地图</th>\n          <th class=\"border border-gray-300 p-2 text-center whitespace-nowrap\">采集点</th>\n          <th class=\"border border-gray-300 p-2 text-center whitespace-nowrap\">产出</th>\n          <th class=\"border border-gray-300 p-2 text-center whitespace-nowrap\">流程</th>\n        </tr>\n      </thead>\n      <tbody>\n        <!-- r1 -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 text-center align-top col-map col-neutral\" rowspan=\"2\">\n            全图\n          </td>\n          <td class=\"border border-gray-300 p-2 col-spot neutral\" rowspan=\"3\">野外</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>骑高负重生物</li>\n                  <li>带跳蛛|星尾兽|吃喝|低温冰箱|电池</li>\n                  <li>到达石头富集区</li>\n                  <li>部署低温冰箱并丢出星尾兽</li>\n                  <li>回收低温冰箱</li>\n                  <li>骑星尾兽敲石头</li>\n                  <li>丢包</li>\n                  <li>抽到身上带回家</li>\n                </ol>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r2 -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>骑高负重生物</li>\n                  <li>带跳蛛|法索拉鳄|吃喝|低温冰箱|电池</li>\n                  <li>到达石头富集区</li>\n                  <li>部署低温冰箱并丢出法索拉鳄</li>\n                  <li>回收低温冰箱</li>\n                  <li>骑法索拉鳄钻地撞石头</li>\n                  <li>丢包</li>\n                  <li>抽到身上带回家</li>\n                </ol>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r3 -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 text-center align-top col-map col-neutral\">除畸变</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <!-- 采集点合并自 r1 -->\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                骑僵尸电龙(僵尸索尔)电野生龙，用电锯锯肉( <span class=\"hl-dot hl-1\">◧</span> )<br><span class=\"md-hl\">电放完后再下龙</span>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n\n        <!-- r4 -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 text-center align-top col-map\" data-map=\"Isl\" rowspan=\"5\">\n            <div class=\"map-badge\">\n              <ha-icon icon=\"mdi:island\"></ha-icon>\n              <div>孤岛</div>\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Isl\" rowspan=\"2\">英灵殿门口</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&KYC\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">骑河狸采“压缩草”</td>\n        </tr>\n        <!-- r5 -->\n        <tr>\n          <!-- 图、采集点合并自 r4 -->\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">镰刀采集</td>\n        </tr>\n        <!-- r6 -->\n        <tr>\n          <!-- 图合并自 r4 -->\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Isl\">2号水洞</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>鮟鱇鱼 置入无线传送箱</li>\n                  <li>脱光放好</li>\n                  <li>传床</li>\n                  <li>丢鱼</li>\n                  <li>采集(岸边|水底)</li>\n                  <li>转移所有</li>\n                  <li>传床回家</li>\n                </ol>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r7 -->\n        <tr>\n          <!-- 图合并自 r4 -->\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Isl\">毒气洞</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>手开泰克发电机</li>\n                  <li>检查目的地盘子是否可到达(不可达看 <span class=\"hl-dot hl-1\">◧</span> )</li>\n                  <li>脱光/带吃喝/带火猫(主动喷火)/穿防毒面具(只穿面具，并带一个备用面具)</li>\n                  <li>丢青蛙</li>\n                  <li>传送</li>\n                  <li>进洞狩猎</li>\n                  <li>手开泰克发电机</li>\n                  <li>传送回家</li>\n                  <li>修复防毒面具</li>\n                </ol>\n                <span class=\"md-hl\">脱光传床到达目的地手开泰克发电机再传回来</span>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r8 -->\n        <tr>\n          <!-- 图合并自 r4 -->\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Isl\">林中湖</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>丢铠护犬(开伴随)</li>\n                  <li>脱光放好</li>\n                  <li>传床(林中湖-上)</li>\n                  <li>收集树脂(从上到下)</li>\n                  <li>犬装载树脂</li>\n                  <li>传床回家</li>\n                  <li>空地卸载树脂</li>\n                  <li>收犬</li>\n                </ol>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n\n        <!-- r9 -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 text-center align-top col-map\" data-map=\"Sco\">\n            <div class=\"map-badge\">\n              <ha-icon icon=\"mdi:fire\"></ha-icon>\n              <div>焦土</div>\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Sco\">东荒油田</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>丢铠护犬(开伴随装背包)</li>\n                  <li>脱光放好</li>\n                  <li>传床</li>\n                  <li>收集</li>\n                  <li>犬装载石油</li>\n                  <li>传床回家</li>\n                  <li>穿装备(强走词条护甲)</li>\n                  <li>空地卸载石油</li>\n                  <li>收犬</li>\n                </ol>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n\n        <!-- r10 -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 text-center align-top col-map\" data-map=\"Abe\" rowspan=\"5\">\n            <div class=\"map-badge\">\n              <ha-icon icon=\"mdi:mushroom\"></ha-icon>\n              <div>畸变</div>\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Abe\">反辐射坦克</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>检查无线箱子(失效重载两次)</li>\n                  <li>脱光/穿好全套防化服/拿吃喝</li>\n                  <li>传到其他图</li>\n                  <li>传回畸变落地反辐射坦克</li>\n                  <li>骑巨犀踩果子</li>\n                  <li>捡黑珍珠</li>\n                  <li>转移所有</li>\n                  <li>传床回家</li>\n                </ol>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r11 -->\n        <tr>\n          <!-- 图合并自 r10 -->\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Abe\">地狱矿场</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>检查目的地盘子是否可到达(不可达看 <span class=\"hl-dot hl-1\">◧</span> )</li>\n                  <li>脱光/穿强走词条护甲/带跳蛛</li>\n                  <li>丢甲龙(强击矿机)</li>\n                  <li>传送</li>\n                  <li>放碎片</li>\n                  <li>打铁/骨头(负重使用跳蛛抽)</li>\n                  <li>转移石头/角质到化学桌</li>\n                  <li>启动泰克发电机</li>\n                  <li>搓水泥</li>\n                  <li>拿走水泥和甲龙一起传送回家</li>\n                </ol>\n                <span class=\"md-hl\">脱光传床到达目的地手开泰克发电机再传回来</span>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r12 -->\n        <tr>\n          <!-- 图合并自 r10 -->\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Abe\" rowspan=\"2\">血池</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>检查目的地盘子是否可到达(不可达看 <span class=\"hl-dot hl-1\">◧</span> )</li>\n                  <li>带跳蛛</li>\n                  <li>丢猩猩</li>\n                  <li>传送</li>\n                  <li>采集(负重使用跳蛛抽)</li>\n                  <li>手开泰克发电机</li>\n                  <li>传送回家</li>\n                </ol>\n                <span class=\"md-hl\">带上必要物品后穿滑翔翼从俯瞰地直接速降</span>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r13 -->\n        <tr>\n          <!-- 图合并自 r10；采集点合并自 r12 -->\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>检查目的地盘子是否可到达(不可达看 <span class=\"hl-dot hl-1\">◧</span> )</li>\n                  <li>脱光/穿强走词条护甲/汽油/电锯</li>\n                  <li>传送</li>\n                  <li>放入1片元素碎片到泰克发电机(不开)</li>\n                  <li>锯树</li>\n                  <li>强走</li>\n                  <li>打开泰克发电机</li>\n                  <li>传送回家</li>\n                </ol>\n                <span class=\"md-hl\">带上必要物品后穿滑翔翼从俯瞰地直接速降</span>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r14 -->\n        <tr>\n          <!-- 图合并自 r10 -->\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Abe\">蓝水晶之森</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>检查目的地盘子是否可到达(不可达看 <span class=\"hl-dot hl-1\">◧</span> )</li>\n                  <li>带跳蛛</li>\n                  <li>丢甲龙(强击矿机)</li>\n                  <li>传送</li>\n                  <li>采集(负重使用跳蛛抽)</li>\n                  <li>手开泰克发电机</li>\n                  <li>传送回家</li>\n                </ol>\n                <span class=\"md-hl\">脱光传床到达目的地手开泰克发电机再传回来</span>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n\n        <!-- r15 -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 text-center align-top col-map\" data-map=\"Ext\" rowspan=\"5\">\n            <div class=\"map-badge\">\n              <ha-icon icon=\"mdi:city\"></ha-icon>\n              <div>灭绝</div>\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Ext\" rowspan=\"3\">荒野</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>脱光/穿泰克头(板子)/强走词条护甲/骑电龙/带莱尼虫/带主动火猫/带螳螂/低温冰箱/电池/铁犒/吃喝/泰克望远镜</li>\n                  <li>关闭电龙资源采集</li>\n                  <li>打开泰克头盔显示</li>\n                  <li>传送<strong>天台A、B</strong>寻找<strong>元素矿脉</strong></li>\n                  <li>防御完成</li>\n                  <li>放置低温冰箱(放电池)</li>\n                  <li>丢螳螂</li>\n                  <li>回收低温冰箱</li>\n                  <li>使用犒子手敲主矿脉15下(剩余血量2100左右)</li>\n                  <li>骑螳螂敲一下</li>\n                  <li>拿走铁犒和资源</li>\n                  <li>收螳螂</li>\n                  <li>开始搓板子</li>\n                  <li>低温症剩120秒时放置低温冰箱(放电池)</li>\n                  <li>丢莱尼虫</li>\n                  <li>收龙收低温冰箱</li>\n                  <li>骑虫回家</li>\n                  <li>扔出火猫</li>\n                </ol>\n                <div><strong>传图步骤（损耗30%）</strong></div>\n                <ol>\n                  <li>使用简易实验桌分解板子成元素粉尘</li>\n                  <li>量小直接转移；量大将粉尘丢出后手动拾取</li>\n                  <li>传图后还原成元素</li>\n                </ol>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        \n        <!-- r17 -->\n        <tr>\n          <!-- 图/采集点合并自 r15 -->\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>脱光/穿泰克头(板子)/强走词条护甲/带火猫/骑梦魇马吸鲨齿/低温冰箱/电池/吃喝/泰克望远镜</li>\n                  <li>打开泰克头盔显示</li>\n                  <li>传送<strong>天台A、B</strong>寻找<strong>红空投</strong></li>\n                  <li>空投点远端释放鲨齿</li>\n                  <li>收梦魇马</li>\n                  <li>远端狩猎补充生肉到3行左右</li>\n                  <li>关闭鲨齿资源采集</li>\n                  <li>防御完成</li>\n                  <li>收战利品</li>\n                  <li>放置低温冰箱(放电池)</li>\n                  <li>丢梦魇马</li>\n                  <li>收低温冰箱</li>\n                  <li>马收鲨齿</li>\n                  <li>骑马回家</li>\n                  <li>检查黑洞低温症</li>\n                  <li>释放鲨齿扔出火猫</li>\n                </ol>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r18 -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 align-top font-semibold col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&TrL\" alt=\"\">\n          </td>\n          <!-- 图/采集点合并自 r15 -->\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>脱光/穿泰克头(板子)/强走词条护甲/带火猫/骑梦魇马吸鲨齿/低温冰箱/电池/吃喝/泰克望远镜/20条帝蟒/1个货运箱/1个空低温仓/未练级Chibi/羽暴龙</li>\n                  <li>打开泰克头盔显示</li>\n                  <li>传送<strong>天台A、B</strong>寻找<strong>紫空投</strong></li>\n                  <li>前往现场规划帝蟒路障位置</li>\n                  <li>释放鲨齿清理现场</li>\n                  <li>收梦魇马</li>\n                  <li>路障点附近放置低温冰箱</li>\n                  <li>迅速丢出规划数量的帝蟒(不要靠近空投点)</li>\n                  <li>全部钻地( <span class=\"hl-dot hl-3\">◧</span> )</li>\n                  <li>收低温冰箱</li>\n                  <li>鲨齿空投点远端狩猎补充生肉到3行左右</li>\n                  <li>关闭鲨齿资源采集</li>\n                  <li>激活空投</li>\n                  <li>波次结束在有卡怪的情况下迅速移动帝蟒到指定路障位置(可分多波次完成移动)</li>\n                  <li>防御完成( <span class=\"hl-dot hl-1\">◧</span> <span class=\"hl-dot hl-2\">◧</span> )</li>\n                  <li>收战利品</li>\n                  <li>吹全体跟随到安全位置收帝蟒</li>\n                  <li>放置低温冰箱(放电池)</li>\n                  <li>丢梦魇马</li>\n                  <li>收低温冰箱</li>\n                  <li>放置货运箱</li>\n                  <li>将超重物品放入并送回家</li>\n                  <li>将剩余超重物品转入鲨齿以及火猫库存</li>\n                  <li>马收鲨齿</li>\n                  <li>骑马回家</li>\n                  <li>检查黑洞低温症</li>\n                  <li>释放鲨齿扔出火猫</li>\n                  <li>等待货运箱降落</li>\n                  <li>拿取所有</li>\n                </ol>\n                <span class=\"md-hl md-hl-3\">如果路障点离空投点较远可先依次钻地移动帝蟒到指定点位</span>\n                <span class=\"md-hl md-hl-1\">不要在帝蟒附近咬气囊虫，否则会强制帝蟒钻出</span>\n                <span class=\"md-hl md-hl-2\">如果出现死神钻地不出，则安全位置放置低温冰箱并放出羽暴龙进行恐惧战吼，用完即收</span>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r19 -->\n        <tr>\n          <!-- 图合并自 r15 -->\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Ext\">集会所改车店</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>脱光/带跳蛛/吃喝</li>\n                  <li>传送</li>\n                  <li>丢星尾兽</li>\n                  <li>采集(负重使用跳蛛抽)</li>\n                  <li>传送回家</li>\n                </ol>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n        <!-- r20 -->\n        <tr>\n          <!-- 图合并自 r15 -->\n          <td class=\"border border-gray-300 p-2 text-left align-top col-spot\" data-map=\"Ext\">西城</td>\n          <td class=\"border border-gray-300 p-2 align-top col-output\">\n            <img src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&UWz\" alt=\"\">\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top col-flow\">\n            <label class=\"clamp-wrap\">\n              <input type=\"checkbox\" class=\"clamp-toggle\">\n              <div class=\"clamp-content\">\n                <ol>\n                  <li>丢铠护犬(开伴随装背包)</li>\n                  <li>丢镰刀龙(公种镰)</li>\n                  <li>骑镰刀龙传送到西城</li>\n                  <li>水边采稀有花</li>\n                  <li>负重后转移到铠护犬</li>\n                  <li>传回家</li>\n                  <li>拿花</li>\n                  <li>收犬</li>\n                </ol>\n              </div>\n              <span class=\"clamp-btn\" aria-hidden=\"true\"></span>\n            </label>\n          </td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n</div>\n",
                          "ignore_line_breaks": true,
                          "always_update": false,
                          "parse_jinja": true,
                          "code_editor": "Ace",
                          "entities": [],
                          "bindings": [],
                          "actions": [],
                          "debounceChangePeriod": 100,
                          "plugins": {
                            "daisyui": {
                              "enabled": true,
                              "url": "https://cdn.jsdelivr.net/npm/daisyui@latest/dist/full.css",
                              "theme": "dark - dark",
                              "overrideCardBackground": false
                            },
                            "tailwindElements": {
                              "enabled": false
                            }
                          },
                          "type": "custom:tailwindcss-template-card",
                          "card_mod": {
                            "style": "ha-card {\n  box-shadow: none !important;\n  padding: 0px !important;\n  font-size: var(--paper-font-body1_-_font-size, 14px) !important;\n  font-family: var(--paper-font-body1_-_font-family, 'Roboto', sans-serif) !important;\n}\n\nha-card table {\n  border-collapse: collapse !important;\n  table-layout: fixed !important;\n}\n\nha-card th, ha-card td {\n  padding: 8px !important;\n  overflow: hidden !important;\n  text-overflow: ellipsis !important;\n}\n\nha-card .sticky {\n  position: sticky !important;\n}\n\nha-card thead th {\n  z-index: 20 !important;\n}\n\n/* 产出列：内容横竖居中（图标居中） */\nha-card tbody td.col-output { text-align: center !important; vertical-align: middle !important; }\nha-card tbody td.col-output img { display: block !important; margin-left: auto !important; margin-right: auto !important; }\n\nha-card h2 {\n  font-family: inherit !important;\n  font-weight: bold !important;\n  margin: 0 0 16px 0 !important;\n  color: var(--primary-text-color) !important;\n  line-height: 1.3 !important;\n}\n\n/* 确保图片不会被压缩 */\nha-card img {\n  flex-shrink: 0 !important;\n}\n\nha-card tbody td img {\n  /* 统一由 card_mod 控制图标尺寸 */\n  width: 40px !important;\n  height: auto !important;\n  min-width: 40px !important;\n}\n\nha-card .border {\n  border-width: 0px 1px 1px 0px !important;\n  border-color: var(--app-theme-color) !important;\n}\n\n/* 为有内容的单元格提供足够的行高 */\nha-card tbody td {\n  line-height: 1.4 !important;\n  vertical-align: top !important;\n  font-size: var(--paper-font-body1_-_font-size, 12px) !important;\n}\n\n/* 取消隔列着色（原有列交替背景移除） */\n\nha-card .borderr {\n  border-top-left-radius: 8px !important;\n  border-top-right-radius: 8px !important;\n  border-bottom-left-radius: var(--ha-card-border-radius, 12px) !important;\n  border-bottom-right-radius: var(--ha-card-border-radius, 12px) !important;\n  height: var(--collect-table-height, 82vh) !important;\n}\n\n/* 头部列宽（首行背景统一为次级背景色）- 顺序：地图 | 采集点 | 产出 | 流程 */\nha-card thead th {\n  border-top: 0 !important;\n  background-color: var(--secondary-background-color, #f5f5f5) !important;\n  color: inherit !important;\n}\nha-card thead th:nth-child(1) {\n  width: 50px !important;\n  min-width: 50px !important;\n  font-weight: 700 !important;\n}\nha-card thead th:nth-child(2) {\n  width: 80px !important;\n  min-width: 80px !important;\n}\nha-card thead th:nth-child(3) {\n  width: 60px !important;\n  min-width: 60px !important;\n}\nha-card thead th:nth-child(4) {\n  width: 190px !important;\n  min-width: 190px !important;\n}\n\n/* 图/采集点/流程列：基于类名控制样式，避免 rowspan 破坏 nth-child 定位 */\nha-card tbody td.col-map {\n  text-align: center !important;\n  vertical-align: middle !important;\n  padding-top: 10px !important;\n  padding-bottom: 10px !important;\n  font-weight: 600 !important;\n}\nha-card .map-badge { display: grid !important; place-items: center !important; row-gap: 4px !important; }\nha-card .map-badge ha-icon { width: 20px !important; height: 20px !important; }\n\n/* 采集点列：内容横竖居中 */\nha-card tbody td.col-spot {\n  text-align: center !important;\n  vertical-align: middle !important;\n  color: #000 !important;\n}\n\n/* 按服务器主题色配置映射：图列使用 primary_color，采集点列使用 light_color */\nha-card td.col-map[data-map=\"Isl\"] { background-color: #4CAF50 !important; color: #fff !important; }\nha-card td.col-spot[data-map=\"Isl\"] { background-color: #81C784 !important; }\n\nha-card td.col-map[data-map=\"Sco\"] { background-color: #FF5722 !important; color: #fff !important; }\nha-card td.col-spot[data-map=\"Sco\"] { background-color: #FF8A65 !important; }\n\nha-card td.col-map[data-map=\"Abe\"] { background-color: #9C27B0 !important; color: #fff !important; }\nha-card td.col-spot[data-map=\"Abe\"] { background-color: #BA68C8 !important; }\n\nha-card td.col-map[data-map=\"Ext\"] { background-color: #00BCD4 !important; color: #fff !important; }\nha-card td.col-spot[data-map=\"Ext\"] { background-color: #4DD0E1 !important; }\n\n/* ‘全图’与‘除畸变’使用深灰底色 */\nha-card td.col-map.col-neutral { background-color: #424242 !important; color: #fff !important; }\n/* ‘野外’使用较浅的深灰底色 */\nha-card td.col-spot.neutral { background-color: #9e9e9e !important; color: #000 !important; }\n\n/* 流程列 与 产出列：隔行着色（从第二行开始着色） */\nha-card tbody tr:nth-child(odd) td.col-flow,\nha-card tbody tr:nth-child(odd) td.col-output { background-color: transparent !important; }\nha-card tbody tr:nth-child(even) td.col-flow,\nha-card tbody tr:nth-child(even) td.col-output { background-color: var(--primary-background-color, #f5f5f5) !important; }\n\n/* 去掉对 rowspan 的视觉补丁：我们不再使用 rowspan 来模拟条纹 */\n/* 可折叠大段文本：默认显示 1 行，点击展开/收起 */ ha-card td .clamp-wrap { display: block !important; } ha-card td .clamp-toggle { display: none !important; } ha-card td .clamp-content {\n  display: -webkit-box !important;\n  -webkit-box-orient: vertical !important;\n  -webkit-line-clamp: 1 !important;\n  overflow: hidden !important;\n} ha-card td .clamp-toggle:checked + .clamp-content {\n  display: block !important;\n  -webkit-line-clamp: initial !important;\n  overflow: visible !important;\n} ha-card td .clamp-btn {\n  display: inline-block !important;\n  margin-top: 6px !important;\n  color: var(--primary-color) !important;\n  cursor: pointer !important;\n  font-size: 12px !important;\n  user-select: none !important;\n} ha-card td .clamp-toggle:not(:checked) ~ .clamp-btn::after { content: '≚'; } ha-card td .clamp-toggle:checked ~ .clamp-btn::after { content: '≙'; }\n\n/* Markdown 风格高亮块：用于标注以 ***** 开头的提示行 */ ha-card td .md-hl {\n  display: block !important;\n  margin: 6px 0 !important;\n  padding: 6px 8px !important;\n  border-left: 3px solid var(--primary-color) !important;\n  background-color: var(--secondary-background-color, rgba(0,0,0,0.06)) !important;\n  border-radius: 4px !important;\n}\n/* 高亮块配色：1号=主色；2号/3号使用不同色 */ ha-card td .md-hl.md-hl-1 { border-left-color: var(--primary-color) !important; } ha-card td .md-hl.md-hl-2 { border-left-color: var(--accent-color, #FF9800) !important; } ha-card td .md-hl.md-hl-3 { border-left-color: var(--info-color, #03A9F4) !important; }\n/* 内联提示 ◧ 的着色 */ ha-card td .hl-dot { font-weight: 700 !important; } ha-card td .hl-dot.hl-1 { color: var(--primary-color) !important; } ha-card td .hl-dot.hl-2 { color: var(--accent-color, #FF9800) !important; } ha-card td .hl-dot.hl-3 { color: var(--info-color, #03A9F4) !important; }\n/* 列表在折叠内容中的缩进与行距优化 */ /* 注意：DaisyUI/Tailwind 会将 ol/ul 的 list-style 重置为 none，这里强制恢复数字序号 */ ha-card td .clamp-content ol { margin: 0 !important; padding-left: 0 !important; list-style: decimal inside !important; } ha-card td .clamp-content li { margin: 0 0 6px 0 !important; }\n"
                          }
                        }
                      },
                      "grid_options": {
                        "columns": 24,
                        "rows": "auto"
                      }
                    }
                  ],
                  "grid_options": {
                    "columns": "full"
                  }
                }
              ],
              "column_span": 2
            }
