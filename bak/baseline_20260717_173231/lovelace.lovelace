                    {
                      "type": "conditional",
                      "conditions": [
                        {
                          "entity": "input_select.info_square_tab",
                          "state": "ASA PC版本"
                        }
                      ],
                      "card": {
                        "type": "custom:mod-card",
                        "card_mod": {
                          "style": "ha-card {\n  box-shadow: none !important;\n}\n"
                        },
                        "card": {
                          "entity": "",
                          "content": "<div class=\"flex flex-col\">\n  <!-- 标题区域 - 增大一个号 -->\n  <h1 class=\"text-3xl font-bold text-left mb-0 m-0\">ASA PC版本</h1>\n  \n  <!-- 补丁内容区域 -->\n  <div class=\"patch-container\">\n    {% set cards = state_attr('sensor.patch_description_full', 'cards') %}\n    {% if cards %}\n      {% for card in cards %}\n        {% if card.type == 'markdown' %}\n          {% if not loop.first %}\n            <!-- 分隔线 - 模拟markdown --- 样式 -->\n            <hr class=\"border-0 h-px mb-0 my-4 mx-0\">\n          {% endif %}\n          <div class=\"prose max-w-none text-left mb-4 leading-relaxed break-all whitespace-pre-line\">\n            {{ card.content | safe }}\n          </div>\n        {% elif card.type == 'iframe' %}\n          <div class=\"mb-4 rounded-xl overflow-hidden\">\n            <iframe \n              src=\"{{ card.url }}\" \n              class=\"w-full aspect-video min-h-[200px] max-h-[400px] border-0 rounded-xl\"\n              frameborder=\"0\"\n              allowfullscreen>\n            </iframe>\n          </div>\n        {% elif card.type == 'picture' %}\n          <div class=\"text-center my-2 w-full relative z-[1]\">\n            <a href=\"{{ card.tap_action.url_path or '#' }}\" \n               target=\"_blank\" \n               class=\"block w-full relative z-[999] no-underline hover:opacity-80 transition-opacity duration-200\"\n               onclick=\"event.stopPropagation(); window.open('{{ card.tap_action.url_path or '#' }}', '_blank'); return false;\">\n              <img src=\"{{ card.image }}\" \n                   alt=\"补丁图片\"\n                   class=\"w-full h-auto {% if card.tap_action.url_path == card.image %}border-0{% else %}border-2 border-blue-500{% endif %} rounded-lg shadow-sm cursor-pointer block relative z-[999] transition-opacity duration-200\">\n            </a>\n          </div>\n        {% endif %}\n      {% endfor %}\n    {% else %}\n      <!-- 如果没有cards属性，回退到原来的content显示方式 -->\n      <div class=\"prose max-w-none text-left mb-4 leading-relaxed break-all whitespace-pre-line\">\n        {{ state_attr('sensor.patch_description_full', 'content') | safe }}\n      </div>\n    {% endif %}\n  </div>\n  \n  <!-- 最后的分隔线 - 增大间距 -->\n  <hr class=\"border-0 h-px mb-6 mx-0\" />\n  \n  <!-- 底部链接图标 -->\n  <div class=\"text-center -mt-2\">\n    <a href=\"https://survivetheark.com/index.php?/forums/\" \n       target=\"_blank\" \n       class=\"inline-block mr-2\">\n      <img src=\"https://ark.wiki.gg/images/thumb/ASA_Logo_transparent.png/198px-ASA_Logo_transparent.png?edb3af\"\n           width=\"48\" \n           height=\"48\" \n           class=\"align-middle\">\n    </a>\n    <a href=\"https://discord.com/channels/729837326120910915/735188487615283232\" \n       target=\"_blank\" \n       class=\"inline-block\">\n      <img src=\"https://hass.whiterober.com/api/image/serve/eb8b3e2a26a52264933c6275fc5bd419/original?authSig=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkZTIwMjk0ZTE3Yzk0ZDEzYWI2ODhmNDZmYTQyODI4OCIsInBhdGgiOiIvYXBpL2ltYWdlL3NlcnZlL2ViOGIzZTJhMjZhNTIyNjQ5MzNjNjI3NWZjNWJkNDE5L29yaWdpbmFsIiwicGFyYW1zIjpbXSwiaWF0IjoxNzU0MjI1MjMwLCJleHAiOjE3NTQzMTE2MzB9.nxJLBE_sHBA30KbHNBCzILcYtWVbD4HPMKNpI9rWYsQ\"\n           width=\"48\" \n           height=\"48\" \n           class=\"align-middle\">\n    </a>\n  </div>\n</div>\n",
                          "ignore_line_breaks": true,
                          "always_update": false,
                          "parse_jinja": true,
                          "code_editor": "Ace",
                          "entities": [],
                          "bindings": [],
                          "actions": [],
                          "debounceChangePeriod": 100,
                          "plugins": {
                            "daisyui": {
                              "enabled": true,
                              "url": "https://cdn.jsdelivr.net/npm/daisyui@latest/dist/full.css",
                              "theme": "dark - dark",
                              "overrideCardBackground": false
                            },
                            "tailwindElements": {
                              "enabled": false
                            }
                          },
                          "type": "custom:tailwindcss-template-card",
                          "card_mod": {
                            "prepend": true,
                            "style": ":host ha-card {\n  box-shadow: none !important;\n  padding: 18px !important;\n  /* 继承 markdown 卡片的基础字体 */\n  font-size: var(--paper-font-body1_-_font-size, 14px) !important;\n  font-family: var(--paper-font-body1_-_font-family, 'Roboto', sans-serif) !important;\n}\n\n/* 重写字体大小以匹配markdown卡片 */\n:host ha-card .prose,\n:host ha-card .prose p,\n:host ha-card .prose div,\n:host ha-card .prose span {\n  font-size: inherit !important;\n  font-family: inherit !important;\n  user-select: text !important;\n}\n\n/* h3 标签继承默认的h3字号，不覆盖字体大小 */\n:host ha-card h3,\n:host ha-card .prose h3 {\n  font-family: inherit !important;\n  font-weight: bold !important;\n  margin: 0 !important;\n  color: var(--primary-text-color) !important;\n  line-height: 1.3 !important;\n  font-size: 1.17em;\n}\n\n:host ha-card p,\n:host ha-card .prose p {\n  margin: -3px 0px !important;\n  line-height: 1.3em !important;\n  padding-left: 1.2em;\n  text-indent: 0;\n  position: relative;\n}\n\n:host ha-card span,\n:host ha-card .prose span {\n  position: relative !important;\n  display: inline-block !important;\n  vertical-align: top;\n  text-align: center !important;\n}\n\n:host ha-card sub,\n:host ha-card .prose sub {\n  display: block !important;\n  font-size: 0.7em !important;\n  max-width: 1080px !important;\n  word-break: break-all !important;\n  width: 100% !important;\n  text-align: center !important;\n  margin: 0 0 0.8em 0 !important;\n  padding: 0 !important;\n}\n\n:host ha-card p::before {\n  content: \"▪\";\n  position: absolute;\n  left: 0;\n  top: 0;\n  width: 1em;\n  text-align: center;\n}\n\n/* 分隔线样式与markdown一致 */\n:host ha-card hr {\n  border: none !important;\n  border-top: 1px solid !important;\n  height: 1px !important;\n  border-color: var(--divider-color) !important;\n}\n\n:host ha-card .prose,\n:host ha-card .prose p,\n:host ha-card .prose div,\n:host ha-card .prose span {\n  user-select: text !important;\n}\n"
                          }
