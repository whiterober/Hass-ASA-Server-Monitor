                    "style": "ha-card {\n  position: relative;\n  box-shadow: none !important;\n  background:\n    {% if is_state('sensor.dialog_server_status', '在线') %}\n      {% set selected_server = states('input_select.selected_server') %}\n      {% set themes = state_attr('sensor.asa_server_themes', 'server_themes') or {} %}\n      {% set theme = themes.get(selected_server, {}) %}\n      {{ theme.get('primary_color', 'var(--primary-color)') }};\n    {% else %}\n      grey;\n    {% endif %}\n}\n:host {\n  --stack-card-gap: 0px !important;\n}\n"
                  },
                  "cards": [
                    {
                      "type": "markdown",
                      "content": "{% set selected_server = states('input_select.selected_server') %} {% set themes = state_attr('sensor.asa_server_themes', 'server_themes') or {} %} {% set theme = themes.get(selected_server, {}) %} # {{ theme.get('emoji', '🎯') }} {{ theme.get('name', '请选择服务器') }}\n",
                      "card_mod": {
                        "style": "ha-card {\n  color: var(--text-primary-color);\n  text-align: left;\n  font-weight: bold;\n  box-shadow: none !important;\n  background:\n    {% set selected_server = states('input_select.selected_server') %}\n    {% set themes = state_attr('sensor.asa_server_themes', 'server_themes') or {} %}\n    {% set theme = themes.get(selected_server, {}) %}\n    {{ theme.get('primary_color', 'var(--primary-color)') }};\n}\n"
                      }
