                    {
                      "type": "conditional",
                      "conditions": [
                        {
                          "condition": "state",
                          "entity": "input_select.info_tribe_tab",
                          "state": "补给速查"
                        }
                      ],
                      "card": {
                        "type": "custom:mod-card",
                        "card_mod": {
                          "style": "ha-card {\n  box-shadow: none !important;\n}\n"
                        },
                        "card": {
                          "entity": "",
                          "content": "<div class=\"section-tab-bar base-title-header\">\n  <div class=\"section-tab tab-active\" onclick=\"(function(el){const root=el.getRootNode?el.getRootNode():document;root.querySelector('#section-yingling-body').classList.remove('collapsed');root.querySelector('#section-longhe-body').classList.add('collapsed');root.querySelectorAll('.section-tab').forEach(t=>t.classList.remove('tab-active'));el.classList.add('tab-active');})(this)\">英灵殿</div>\n  <div class=\"section-tab\" onclick=\"(function(el){const root=el.getRootNode?el.getRootNode():document;root.querySelector('#section-longhe-body').classList.remove('collapsed');root.querySelector('#section-yingling-body').classList.add('collapsed');root.querySelectorAll('.section-tab').forEach(t=>t.classList.remove('tab-active'));el.classList.add('tab-active');})(this)\">龙舍</div>\n</div>\n\n<div id=\"section-longhe-body\" class=\"accordion-body collapsed\">\n<div class=\"flex flex-col\">\n  <div class=\"borderr-top relative overflow-auto border border-gray-300\">\n    <table class=\"table-fixed border-collapse w-full min-w-max\">\n      <tbody>\n        <tr>\n          <td class=\"border border-gray-300 p-2 text-left align-top\">\n            <div class=\"location-chip-wrapper\"><span class=\"location-chip location-chip-left\">繁育</span><span class=\"location-chip-badge\">M</span></div>\n            <span class=\"location-chip\">蛋场</span>\n            <span class=\"location-chip\">烤肉</span>\n            <span class=\"location-chip\">风干</span>\n            <span class=\"location-chip\">堆肥</span>\n            <span class=\"location-chip\">厨房</span>\n          </td>\n        </tr>\n      </tbody>\n    </table>\n  </div>\n</div>\n<div class=\"flex flex-col\">\n  <!-- 存储表格 -->\n  <div class=\"borderr-none relative overflow-auto border border-gray-300\">\n    <table id=\"base-table\" class=\"table-fixed border-collapse w-full min-w-max\">\n      <thead class=\"sticky top-0 z-20\">\n        <tr>\n          <th class=\"border border-gray-300 p-2 text-center whitespace-nowrap header-primary\">设备</th>\n          <th class=\"border border-gray-300 p-2 text-center whitespace-nowrap header-primary\" colspan=\"2\">存储</th>\n        </tr>\n      </thead>\n      <tbody>\n        <!-- 冰箱 + 绵羊存储 -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 text-left align-top\">\n            <div class=\"device-container with-modal\" tabindex=\"0\">\n              <div class=\"materials-box\">\n                <span class=\"bio-capacity-tag-bottom\">7<sub>2</sub></span>\n                <div class=\"materials-box-inner materials-box-inner-vertical\">\n                  <div class=\"device-icon-wrapper device-icon-wrapper-vertical\">\n                    <img src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735196072571-63ffdf9b-383d-4902-8fb7-4f681851a5a0.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Cryofridge\" />\n                  </div>\n                  <div class=\"h-divider\"></div>\n                  <div class=\"action-icon-wrapper\">\n                    <svg t=\"1769008871160\" class=\"icon\" viewBox=\"0 0 1024 1024\" version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\" p-id=\"13760\">\n                      <path d=\"M788.48 410.112h-112.128c-24.064 0-92.16 11.776-115.2-2.56-4.608-16.384 10.24-46.08 14.336-60.416 11.776-41.472 23.04-82.432 34.816-124.416L660.48 41.984c6.656-23.552-24.064-33.792-36.864-15.872L218.112 582.656c-9.216 12.8 3.584 30.72 17.92 30.72h164.352c11.264 0 54.784-7.168 61.952 3.584 6.656 8.704-6.144 35.84-8.704 45.568-30.72 106.496-60.416 212.992-90.112 319.488-6.656 23.552 24.064 33.792 36.864 15.872l404.992-556.544c9.728-13.312-2.56-31.232-16.896-31.232z\" fill=\"#f9f352\" p-id=\"13761\"></path>\n                    </svg>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\" colspan=\"2\">\n            <div class=\"flex flex-wrap gap-1 items-start\">\n              <span class=\"icon-mask icon-mask-30\" style=\"--icon-url: url('https://pic.whiterober.com/index.php?mod=io&op=getImg&&l76');\" aria-label=\"Ovis\" role=\"img\"></span>\n            </div>\n          </td>\n        </tr>\n\n        <!-- 冰箱 - KIBBLE & CUS, MEAT -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 text-left align-top\">\n            <div class=\"device-container\">\n              <div class=\"materials-box\">\n                <span class=\"bio-capacity-tag-bottom\">8<sub>0</sub></span>\n                <div class=\"materials-box-inner materials-box-inner-vertical\">\n                  <div class=\"device-icon-wrapper device-icon-wrapper-vertical\">\n                    <img src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735190827833-a09b6e1c-e82c-442a-a3d6-4fc6743c1e04.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Refrigerator\" />\n                  </div>\n                  <div class=\"h-divider\"></div>\n                  <div class=\"action-icon-wrapper\">\n                    <svg t=\"1769008871160\" class=\"icon\" viewBox=\"0 0 1024 1024\" version=\"1.1\" xmlns=\"http://www.w3.org/2000/svg\" p-id=\"13760\">\n                      <path d=\"M788.48 410.112h-112.128c-24.064 0-92.16 11.776-115.2-2.56-4.608-16.384 10.24-46.08 14.336-60.416 11.776-41.472 23.04-82.432 34.816-124.416L660.48 41.984c6.656-23.552-24.064-33.792-36.864-15.872L218.112 582.656c-9.216 12.8 3.584 30.72 17.92 30.72h164.352c11.264 0 54.784-7.168 61.952 3.584 6.656 8.704-6.144 35.84-8.704 45.568-30.72 106.496-60.416 212.992-90.112 319.488-6.656 23.552 24.064 33.792 36.864 15.872l404.992-556.544c9.728-13.312-2.56-31.232-16.896-31.232z\" fill=\"#f9f352\" p-id=\"13761\"></path>\n                    </svg>\n                  </div>\n                </div>\n              </div>\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\">\n            <blockquote class=\"quote\">\n              <div><span class=\"text-bold\">MEAT</span></div>\n              <div class=\"flex flex-wrap gap-1 items-start mt-2\">\n                <img class=\"icon-mask-25\" src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&s6y\" alt=\"Cooked Meat\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735114960510-1e26d418-a866-48cf-b7ec-9e8b445a3dba.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Cooked Prime Meat\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735114970330-91562dea-b3bc-4a69-b011-7da7078f3fe3.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Cooked Lamb Chop\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735114801047-ccbed490-1a66-4905-bd15-57f181f2ef13.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Cooked Meat Jerky\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735114818189-44dce7ff-8d9b-4f8c-9bf0-e150e75f6bcc.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Prime Meat Jerky\" />\n              </div>\n            </blockquote>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\">\n            <blockquote class=\"quote\">\n              <div><span class=\"text-bold\">KIBBLE & CUS</span></div>\n              <div class=\"flex flex-wrap gap-1 items-start mt-2\">\n                <img class=\"icon-mask-25\" src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&s6y?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Kibble\" />\n                <img class=\"icon-mask-25\" src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&hB8\" alt=\"White Burger\" />\n                <img class=\"icon-mask-25\" src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&hB8\" alt=\"White Meat Steak\" />\n                <img class=\"icon-mask-25\" src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&hB8\" alt=\"White Cake\" />\n              </div>\n            </blockquote>\n          </td>\n        </tr>\n\n        <!-- 保险库 - FTHR & COLOR -->\n        <tr>\n          <td class=\"border border-gray-300 p-2 text-left align-top\">\n            <div class=\"device-container\">\n              <div class=\"materials-box\">\n                <span class=\"bio-capacity-tag-bottom\">3<sub>50</sub></span>\n                <div class=\"materials-box-inner materials-box-inner-vertical\">\n                  <div class=\"device-icon-wrapper device-icon-wrapper-vertical\">\n                    <img src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735189891476-e84e3e92-ab5e-4be8-91d2-feb1a7aef3d6.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Vault\" />\n                  </div>\n                </div>\n              </div>\n            </div>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\">\n            <blockquote class=\"quote\">\n              <div class=\"flex flex-wrap gap-1 items-start\">\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735109953478-ccfface3-5bf3-4fef-97ef-e44400ec2cfc.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Hide\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735116071105-6350b3c9-8011-4e09-930c-762739d903ce.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Stone\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735109962540-11e99c91-d538-4d45-bc82-ee8c9550fbbb.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Pelt\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1736831628724-b06a2595-cfbf-49f0-805b-70955a3e8c3f.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Wool\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735109772598-1eb7f311-5df2-47cf-b040-a2b974dd6ef3.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Metal Ingot\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735111302662-5c2e6dc1-e0dc-4414-8b9e-e73934d895be.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Chitin\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735111310790-f581c8b4-8d2a-485f-bfd0-714f8fa24bb9.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Keratin\" />\n                <img class=\"icon-mask-25\" src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&uxX\" alt=\"Fiber\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/webp/12910194/1734964085058-cf0ce2fa-3cd4-40c1-9dcb-795f1f369905.webp\" alt=\"Flint\" />\n              </div>\n            </blockquote>\n          </td>\n          <td class=\"border border-gray-300 p-2 text-left align-top\">\n            <blockquote class=\"quote\">\n              <div><span class=\"text-bold\">FTHR</span></div>\n              <div class=\"flex flex-wrap gap-1 items-start mt-2\">\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735196172750-72e90dc0-8216-4c94-b436-85a516ca698f.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Gigantoraptor Feather\" />\n              </div>\n            </blockquote>\n            <blockquote class=\"quote\">\n              <div><span class=\"text-bold\">COLOR</span></div>\n              <div class=\"flex flex-wrap gap-1 items-start mt-2\">\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735976346227-71d7d178-e9cf-4f34-9a20-db94298b4ca1.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Soap\" />\n                <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735980602229-ea1c26e0-ef06-45c0-b5d1-2ded02e46