ge%2Fformat%2Cwebp\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1734961300130-a3773597-788b-4bec-baf1-c0b0cc23a908.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735987721588-6875cfa7-9bc6-477f-b612-4427c31e5a33.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735987721630-48ec9695-c704-4281-bc25-69bbba51acde.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735976316275-458432ff-1faf-4718-94f1-45ed502fe7b6.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                </div>\n                  </blockquote>\n            </td>\n            </tr>\n            <tr>\n            <td class=\"border border-gray-300 p-2 text-left align-top\">\n                <div class=\"device-container\">\n                  <div class=\"materials-box\">\n                    <span class=\"bio-capacity-tag-bottom\">4<sub>5</sub></span>\n                    <div class=\"materials-box-inner materials-box-inner-vertical\">\n                      <div class=\"device-icon-wrapper device-icon-wrapper-vertical\">\n                        <img class=\"icon-mask-30\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735979323913-a86e6574-882a-40c2-8260-7efffade8841.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Large Storage Box.png\" />\n                      </div>\n                    </div>\n                  </div>\n                </div>\n            </td>\n              <td class=\"border border-gray-300 p-2 text-left align-top\">\n                <blockquote class=\"quote\">\n                <div><span class=\"text-bold\">Chem.</span></div>\n                <div class=\"flex flex-wrap gap-1 items-start mt-2\">\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735976254110-127ec079-eba9-45da-be0c-b988b0cbb3d4.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Beer Jar.png\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735976337059-8523b4fd-89a9-4c92-9ec8-58cd0b1249b1.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Re-Fertilizer.png.png\" />\n                </div>\n                </blockquote>\n                <blockquote class=\"quote quote-spaced\">\n                <div><span class=\"text-bold\">TROPHY </span><span class=\"text-green\">孤岛战利品</span></div>\n                </blockquote>\n            </td>\n              <td class=\"border border-gray-300 p-2 text-left align-top\">\n                <blockquote class=\"quote\">\n                <div><span class=\"text-orange\">■ </span><span class=\"text-bold text-green\">孤岛常用</span></div>\n                <div class=\"mt-2\">\n                    <img class=\"icon-mask-25\" src=\"https://pic.whiterober.com/index.php?mod=io&op=getImg&&Xp4\" alt=\"Untitled Phero.png.png\" />\n                </div>\n                </blockquote>\n                <blockquote class=\"quote quote-spaced\">\n                <div><span class=\"text-bold\">BOSS </span><span class=\"text-green\">孤岛首领战利品</span></div>\n                </blockquote>\n            </td>\n            </tr>\n            <tr>\n            <td class=\"border border-gray-300 p-2 text-left align-top\">\n                <div class=\"device-container\">\n                  <div class=\"materials-box\">\n                    <span class=\"bio-capacity-tag-bottom\">3<sub>50</sub></span>\n                    <div class=\"materials-box-inner materials-box-inner-vertical\">\n                      <div class=\"device-icon-wrapper device-icon-wrapper-vertical\">\n                        <img class=\"icon-mask-30\" src=\"https://cdn.nlark.com/yuque/0/2024/png/12910194/1735189891476-e84e3e92-ab5e-4be8-91d2-feb1a7aef3d6.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Vault.png\" />\n                      </div>\n                    </div>\n                  </div>\n                </div>\n            </td>\n              <td class=\"border border-gray-300 p-2 text-left align-top\">\n                <blockquote class=\"quote\">\n                <div><span class=\"text-bold\">AMMO</span></div>\n                <div class=\"flex flex-wrap gap-1 items-start mt-2\">\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735987421464-dc638ef8-d937-4250-933f-74bc9cd264cc.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735988062740-f6195d14-fcc3-49e6-83fc-f9f4dc6c69b1.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735988075466-7593b929-e927-4597-b86e-c7fc3b8754db.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735988120265-c365d2ca-11aa-45a7-bf79-ddb00076eb15.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735988132599-45cc1d71-fce9-4788-b8d0-2e8377e1a375.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735988144509-896e9908-8775-4ec4-80ff-7668d25bf6c2.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                    <img class=\"icon-mask-25\" src=\"https://cdn.nlark.com/yuque/0/2025/png/12910194/1735988244276-98f19a1e-076b-4d48-89fc-9e520f9214a9.png?x-oss-process=image%2Fformat%2Cwebp\" />\n                </div>\n                  </blockquote>\n                  <blockquote class=\"quote quote-spaced\">\n                  <div><span class=\"text-bold\">WEP </span><span class=\"text-green\">孤岛武器</span></div>\n                  </blockquote>\n                  <blockquote class=\"quote quote-spaced\">\n                  <div><span class=\"text-bold\">ARMOR </span><span class=\"text-green\">孤岛护甲</span></div>\n                  </blockquote>\n            </td>\n            <td class=\"border border-gray-300 p-2 text-left align-top\">\n                  <blockquote class=\"quote\">\n                  <div><span class=\"text-bold\">STRUCT </span><span class=\"text-green\">孤岛其它结构</span></div>\n                <div>茅草|木头|石头 建筑</div>\n                </blockquote>\n                  <blockquote class=\"quote quote-spaced\">\n                  <div><span class=\"text-bold\">SADDLE </span><span class=\"text-green\">孤岛龙鞍</span></div>\n                  </blockquote>\n                  <blockquote class=\"quote quote-spaced\">\n                  <div><span class=\"text-bold\">TOOL </span><span class=\"text-green\">孤岛工具</span></div>\n                  </blockquote>\n                  <blockquote class=\"quote quote-spaced\">\n                  <div><span class=\"text-bold\">SKIN </span>皮肤</div>\n                  </blockquote>\n                  <blockquote class=\"quote quote-spaced\">\n                  <div><span class=\"text-whiter\">■</span></div>\n                  </blockquote>\n            </td>\n            </tr>\n        </tbody>\n        </table>\n    </div>\n</div>\n\n<div class=\"flex flex-col\">\n  <!-- 基地信息表格 -->\n  <div class=\"borderr-none relative overflow-auto border border-gray-300\">\n    <table id=\"base-table\" class=\"table-fixed border-collapse w-full min-w-max\">\n      <thead class=\"sticky top-0 z-20\">\n        <tr>\n          <th class=\"border border-gray-300 p-2 text-center whitespace-nowrap header-primary\">设备</th>\n          <th class=\"border border-gray-300 p-2 text-center whitespace-nowrap header-primary\">原料</th>\n          <th class=\"border border-gr