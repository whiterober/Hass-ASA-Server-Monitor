9bfc-244f4b2218f3.png?x-oss-process=image%2Fformat%2Cwebp\" alt=\"Cooked Prime Meat\" />\n              </div>\n              <!-- <div class=\"qty-btn-group\">\n                <button class=\"qty-btn\" data-type=\"grill-meat\" data-action=\"minus\" style=\"opacity:0.3\" onclick=\"if(this._isTouched){this._isTouched=false;return}(()=>{const type='grill-meat';const root=this.getRootNode();const config={'grill-meat':{output:40,max:400,time:60,materials:[{selector:'[data-material=&quot;raw-meat-grill&quot;]',base:1}]}};const recipe=config[type];if(!recipe)return;const outputEl=root.querySelector(`[data-output=&quot;${type}&quot;]`);const timeEl=root.querySelector(`[data-time=&quot;${type}&quot;]`);if(!outputEl||!timeEl)return;const currQty=parseInt(outputEl.textContent.replace(/[^\\d]/g,''))||recipe.output;if(currQty<=recipe.output)return;let newQty=currQty-recipe.output;const multiplier=newQty/recipe.output;outputEl.textContent='×'+newQty;recipe.materials.forEach(mat=>{const el=root.querySelector(mat.selector);if(el)el.textContent=Math.ceil(mat.base*multiplier)});const secs=recipe.time*multiplier;let displayVal,unit;if(secs>=3600){displayVal=Math.round(secs/3600);unit='h';}else if(secs>=60){displayVal=Math.round(secs/60);unit='m';}else{displayVal=Math.round(secs);unit='s';}timeEl.textContent=displayVal+unit;const minusBtn=root.querySelector(`[data-type=&quot;${type}&quot;][data-action=&quot;minus&quot;]`);const plusBtn=root.querySelector(`[data-type=&quot;${type}&quot;][data-action=&quot;plus&quot;]`);if(minusBtn)minusBtn.style.opacity=newQty<=recipe.output?'0.3':'1';if(plusBtn)plusBtn.style.opacity=newQty>=recipe.max?'0.3':'1'})()\" oncontextmenu=\"event.preventDefault();(()=>{const type='grill-meat';const root=this.getRootNode();const config={'grill-meat':{output:40,max:400,time:60,materials:[{selector:'[data-material=&quot;raw-meat-grill&quot;]',base:1}]}};const recipe=config[type];if(!recipe)return;const outputEl=root.querySelector(`[data-output=&quot;${type}&quot;]`);const timeEl=root.querySelector(`[data-time=&quot;${type}&quot;]`);if(!outputEl||!timeEl)return;let newQty=recipe.output;const multiplier=newQty/recipe.output;outputEl.textContent='×'+newQty;recipe.materials.forEach(mat=>{const el=root.querySelector(mat.selector);if(el)el.textContent=Math.ceil(mat.base*multiplier)});const secs=recipe.time*multiplier;let displayVal,unit;if(secs>=3600){displayVal=Math.round(secs/3600);unit='h';}else if(secs>=60){displayVal=Math.round(secs/60);unit='m';}else{displayVal=Math.round(secs);unit='s';}timeEl.textContent=displayVal+unit;const minusBtn=root.querySelector(`[data-type=&quot;${type}&quot;][data-action=&quot;minus&quot;]`);const plusBtn=root.querySelector(`[data-type=&quot;${type}&quot;][data-action=&quot;plus&quot;]`);if(minusBtn)minusBtn.style.opacity=newQty<=recipe.output?'0.3':'1';if(plusBtn)plusBtn.style.opacity=newQty>=recipe.max?'0.3':'1'})()\" ontouchstart=\"this._isTouched=true;this._t=Date.now()\" ontouchend=\"(()=>{const isLong=(Date.now()-(this._t||0))>=500;const type='grill-meat';const root=this.getRootNode();const config={'grill-meat':{output:40,max:400,time:60,materials:[{selector:'[data-material=&quot;raw-meat-grill&quot;]',base:1}]}};const recipe=config[type];if(!recipe)return;const outputEl=root.querySelector(`[data-output=&quot;${type}&quot;]`);const timeEl=root.querySelector(`[data-time=&quot;${type}&quot;]`);if(!outputEl||!timeEl)return;const currQty=parseInt(outputEl.textContent.replace(/[^\\d]/g,''))||recipe.output;if(!isLong&&currQty<=recipe.output)return;let newQty=isLong?recipe.output:currQty-recipe.output;const multiplier=newQty/recipe.output;outputEl.textContent='×'+newQty;recipe.materials.forEach(mat=>{const el=root.querySelector(mat.selector);if(el)el.textContent=Math.ceil(mat.base*multiplier)});const secs=recipe.time*multiplier;let displayVal,unit;if(secs>=3600){displayVal=Math.round(secs/3600);unit='h';}else if(secs>=60){displayVal=Math.round(secs/60);unit='m';}else{displayVal=Math.round(secs)