                          "content": "<img src=x onerror=\"var d=this.parentElement;function A(){var b=getComputedStyle(document.documentElement).getPropertyValue('--primary-background-color');var m=b.match(/\\d+/g);if(m){d.setAttribute('data-theme',(0.299*m[0]+0.587*m[1]+0.114*m[2])<50?'dark':'light')}}A();new MutationObserver(A).observe(document.documentElement,{attributes:true,attributeFilter:['style']});var m=navigator.userAgent.match(/Chrome\\/(\\d+)/);if(m&&parseInt(m[1])<120)d.setAttribute('data-old-webkit','')\" style=display:none><div class=\"flex flex-col\">\n<div style=\"display:flex;align-items:center;gap:10px;margin:12px 0\"><hr class=\"tb-divider tb-div-wavy\" style=\"flex:1;min-width:0;--div-color:#4CAF50;--div-opacity:1\" /><span style=\"white-space:nowrap;font-size:0.85em;color:#4CAF50;\">GameUserSettings.ini</span><hr class=\"tb-divider tb-div-wavy\" style=\"flex:1;min-width:0;--div-color:#4CAF50;--div-opacity:1\" /></div>\n<div class=\"info-card-block ic-linear-_default\" data-map=\"\" style=\"border-left-color:#4CAF50 !important\">\n<div class=\"ic-body\" style=\"display:flex;flex-wrap:wrap;gap:4px;align-items:center\">\n<div class=\"ic-title\" style=\"flex-basis:100%\">\n<span>🔫 平台可安装自动炮塔</span>\n</div>\n<div class=\"ic-text ic-linear-_default\" style=\"font-weight:bold;\" data-server=\"\" data-server-states='{\"_default\": 1}'>开启</div>\n<div class=\"ic-br\" style=\"flex-basis:100%;height:0\"></div>\n<div class=\"ic-text ic-linear-_default\" style=\"opacity:0.45;\" data-server=\"\" data-server-states='{\"_default\": 1}'>OverrideStructurePlatformPrevention=True</div>\n</div>\n</div>\n<div class=\"info-card-block ic-linear-_default\" data-map=\"\" style=\"border-left-color:#4CAF50 !important\">\n<div class=\"ic-body\" style=\"display:flex;flex-wrap:wrap;gap:4px;align-items:center\">\n<div class=\"ic-title\" style=\"flex-basis:100%\">\n<span>🎁 建筑顶部可刷新补给箱</span>\n</div>\n<div class=\"ic-text ic-linear-_default\" style=\"font-weight:bold;\" data-serv