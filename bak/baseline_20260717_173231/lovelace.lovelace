                      "card": {
                        "type": "custom:mod-card",
                        "card_mod": {
                          "style": "ha-card {\n  box-shadow: none !important;\n  background: transparent !important;\n}\n"
                        },
                        "card": {
                          "entity": "",
                          "content": "<img src=x onerror=\"var d=this.parentElement;function A(){var b=getComputedStyle(document.documentElement).getPropertyValue('--primary-background-color');var m=b.match(/\\d+/g);if(m){d.setAttribute('data-theme',(0.299*m[0]+0.587*m[1]+0.114*m[2])<50?'dark':'light')}}A();new MutationObserver(A).observe(document.documentElement,{attributes:true,attributeFilter:['style']});var m=navigator.userAgent.match(/Chrome\\/(\\d+)/);if(m&&parseInt(m[1])<120)d.setAttribute('data-old-webkit','')\" style=display:none><div class=\"flex flex-col\">\n<div class=\"info-card-block ic-block-_hint\" data-map=\"\" style=\"border-left-color:#2196F3 !important\">\n<div class=\"ic-body\" style=\"display:flex;flex-wrap:wrap;gap:4px;align-items:center\">\n<div class=\"ic-title\" style=\"flex-basis:100%\">\n<ha-icon icon=\"mdi:information\" style=\"--mdc-icon-size:16px;width:16px;height:16px;margin-right:4px;color:#2196F3\"></ha-icon>\n<span style=\"color:#2196F3;\">代码详见</span>\n</div>\n<div class=\"ic-text ic-linear-_default\" data-server=\"\" data-server-states='{\"_default\": 1}'>Beacon的Whiterober工程</div>\n</div>\n</div>\n<div style=\"display:flex;align-items:center;gap:10px;margin:12px 0\"><hr class=\"tb-divider tb-div-wavy\" style=\"flex:1;min-width:0;--div-color:#FF9800;--div-opacity:1\" /><span style=\"white-space:nowrap;font-size:0.85em;color:#FF9800;\">Game.ini</span><hr class=\"tb-divider tb-div-wavy\" style=\"flex:1;min-width:0;--div-color:#FF9800;--div-opacity:1\" /></div>\n<div class=\"info-card-block ic-block-Abe\" data-map=\"Abe\" style=\"border-left-color:#9C27B0 !important\">\n<div class=\"ic-body\" style=\"display:flex;flex-wrap:wrap;gap:4px;align-items:center\">\n<div class=\"ic-title\" style=\"flex-basis:100%\">\n<ha-icon icon=\"mdi:radioactive\" style=\"--mdc-icon-size:16px;width:16px;height:16px;margin-right:4px;color:#9C27B0\"></ha-icon>\n<span style=\"color:#9C27B0;\">🎁 畸变地下宝箱</span>\n</div>\n<div class=\"ic-text ic-block-_warn\" styl