ant}ha-card .ig-row-wrapper.ic-linear-Bob::after{border-top-color:#FFC107!important;opacity:0.4!important}ha-card .ig-title-row ha-icon,ha-card .ig-title-badge ha-icon{color:inherit!important}ha-card .icon-group{gap:8px!important}ha-card .ig-item{position:relative!important;display:inline-flex!important;flex-shrink:0!important}ha-card .ig-img{width:28px!important;height:28px!important;object-fit:contain!important;border-radius:4px!important}ha-card .ig-item .ic-qty{position:absolute!important;right:-2px!important;bottom:-2px!important;font-size:0.65em!important;white-space:nowrap!important;word-break:normal!important;padding-right:0!important}ha-card .ig-img.ic-auto-dark{filter:none!important}ha-card .ig-img.ic-auto-light{filter:none!important}[data-theme=\"dark\"] .ig-img.ic-auto-dark{filter:invert(1)!important}[data-theme=\"light\"] .ig-img.ic-auto-light{filter:invert(1)!important}ha-card .ic-copy-key{display:inline-flex!important;align-items:center!important;gap:4px!important;padding:2px 6px!important;border-radius:6px!important;border:none!important;background:#0288d1!important;color:var(--primary-background-color)!important;cursor:pointer!important;font-size:0.9em!important;font-weight:400!important;line-height:1.5!important;transition:filter 0.2s!important}ha-card .ic-copy-key:hover{filter:brightness(1.15)!important}ha-card .ic-copy-key ha-icon{color:var(--primary-background-color)!important} ha-card ha-icon{line-height:0!important} ha-card div.flex.flex-col>div:not([class]){margin-top:0!important}"
