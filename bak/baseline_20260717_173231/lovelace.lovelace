                      "card": {
                        "type": "custom:mod-card",
                        "card_mod": {
                          "style": "ha-card {\n  box-shadow: none !important;\n}\n"
                        },
                        "card": {
                          "entity": "",
                          "content": "<div class=\"flex flex-col\">\n  <!-- 标题区域 - 增大一个号 -->\n  <h1 class=\"text-3xl font-bold text-left mb-0 m-0\">汉化版本</h1>\n  \n  <!-- 贴吧内容区域 -->\n  <div class=\"tieba-container\">\n    {% set cards = state_attr('sensor.tieba_lz_full', 'cards') %}\n    {% if cards %}\n      {% for card in cards %}\n        {% if card.type == 'markdown' %}\n          {% if not loop.first %}\n            <!-- 分隔线 - 模拟markdown --- 样式 -->\n            <hr class=\"border-0 h-px mb-0 my-4 mx-0\">\n          {% endif %}\n          <div class=\"prose max-w-none text-left mb-4 leading-relaxed break-all whitespace-pre-line\">\n            {{ card.content | safe }}\n          </div>\n        {% elif card.type == 'iframe' %}\n          <div class=\"mb-4 rounded-xl overflow-hidden\">\n            <iframe \n              src=\"{{ card.url }}\" \n              class=\"w-full aspect-video min-h-[200px] max-h-[400px] border-0 rounded-xl\"\n              frameborder=\"0\"\n              allowfullscreen>\n            </iframe>\n          </div>\n        {% elif card.type == 'picture' %}\n          <div class=\"text-center my-2 w-full relative z-[1]\">\n            <a href=\"{{ card.tap_action.url_path or '#' }}\" \n               target=\"_blank\" \n               class=\"block w-full relative z-[999] no-underline hover:opacity-80 transition-opacity duration-200\"\n               onclick=\"event.stopPropagation(); window.open('{{ card.tap_action.url_path or '#' }}', '_blank'); return false;\">\n              <img src=\"{{ card.image }}\" \n                   alt=\"贴吧图片\"\n                   class=\"w-full h-auto {% if card.tap_action.url_path == card.image %}border-0{% else %}border-2 border-blue-500{% endif %} rounded-lg shadow-sm cursor-pointer block relative z-[999] transition-opacity duration-200\">\n            </a>\n          </div>\n        {% endif %}\n      {% endfor %}\n    {% else %}\n      <!-- 如果没有cards属性，回退到原来的content显示方式 -->\n      <div class=\"prose max-w-none text-left mb-4 leading-relaxed break-all whitespace-pre-line\">\n        {{ state_attr('sensor.tieba_lz_full', 'content') | safe }}\n      </div>\n    {% endif %}\n  </div>      \n  <!-- 最后的分隔线 - 增大间距 -->\n  <hr class=\"border-0 h-px mb-6 mx-0\" />\n    \n    <!-- 添加固定的网盘信息 -->\n    <div class=\"mt-0 mb-6 p-3 bg-blue-50 dark:bg-blue-900/20 rounded-lg border border-blue-200 dark:border-blue-800\">\n      <div class=\"text-sm font-semibold text-blue-800 dark:text-blue-200 mb-2\">\n        <span class=\"inline-block mr-2\">✨</span>123网盘包含汉化+修正\n      </div>\n      <div class=\"text-sm font-semibold text-blue-800 dark:text-blue-200\">\n        <span class=\"inline-block mr-2\">✨</span>百度网盘包含修正\n      </div>\n    </div>\n  </div>\n  \n  <!-- 底部链接图标 -->\n  <div class=\"text-center -mt-2\">\n    <a href=\"https://tieba.baidu.com/p/9023236354?see_lz=1\" \n       target=\"_blank\" \n       class=\"inline-block mr-2\">\n      <img src=\"https://hass.whiterober.com/api/image/serve/3c5c0186c4f0bee295243d2919ee61d4/original?authSig=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkZTIwMjk0ZTE3Yzk0ZDEzYWI2ODhmNDZmYTQyODI4OCIsInBhdGgiOiIvYXBpL2ltYWdlL3NlcnZlLzNjNWMwMTg2YzRmMGJlZTI5NTI0M2QyOTE5ZWU2MWQ0L29yaWdpbmFsIiwicGFyYW1zIjpbXSwiaWF0IjoxNzU0MjI1MjAwLCJleHAiOjE3NTQzMTE2MDB9.NDyqyrsa1TpmByyeNXsZMbhCVXzBqToP3VoLwdGvqAA\"\n           width=\"48\" \n           height=\"48\" \n           class=\"align-middle\">\n    </a>\n    <a href=\"https://www.123pan.com/s/U7ztVv-VC4xA.html\" \n       target=\"_blank\" \n       class=\"inline-block mr-2\">\n      <img src=\"https://hass.whiterober.com/api/image/serve/df5aa3f3711fa11a49b2865dc4ba471f/original?authSig=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkZTIwMjk0ZTE3Yzk0ZDEzYWI2ODhmNDZmYTQyODI4OCIsInBhdGgiOiIvYXBpL2ltYWdlL3NlcnZlL2RmNWFhM2YzNzExZmExMWE0OWIyODY1ZGM0YmE0NzFmL29yaWdpbmFsIiwicGFyYW1zIjpbXSwiaWF0IjoxNzU0MjI1MTc5LCJleHAiOjE3NTQzMTE1Nzl9.aA6CMQYNxhmqM2L6_Blt7TUooplASwazjEh1uLMBNFk\"\n           width=\"48\" \n           height=\"48\" \n           class=\"align-middle\">\n    </a>\n    <a href=\"https://pan.baidu.com/s/1QdFzVmRzWVTAnDXPrOBZ6A?pwd=9ggf&_at_=1754223951264#list/path=%2F\" \n       target=\"_blank\" \n       class=\"inline-block mr-2\">\n      <img src=\"https://hass.whiterober.com/api/image/serve/44c1d0a968f8ba1ebf683655510f7957/original?authSig=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkZTIwMjk0ZTE3Yzk0ZDEzYWI2ODhmNDZmYTQyODI4OCIsInBhdGgiOiIvYXBpL2ltYWdlL3NlcnZlLzQ0YzFkMGE5NjhmOGJhMWViZjY4MzY1NTUxMGY3OTU3L29yaWdpbmFsIiwicGFyYW1zIjpbXSwiaWF0IjoxNzU0MjI1MTUzLCJleHAiOjE3NTQzMTE1NTN9.vpeXL2_k4SOqK0tlABUhyEUsmrHhBApgber-WZIz2RM\"\n           width=\"48\" \n           height=\"48\" \n           class=\"align-middle\">\n    </a>\n    <a href=\"https://discord.com/channels/1383688657449259109/1385033726622306354\" \n       target=\"_blank\" \n       class=\"inline-block\">\n      <img src=\"https://hass.whiterober.com/api/image/serve/eb8b3e2a26a52264933c6275fc5bd419/original?authSig=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJkZTIwMjk0ZTE3Yzk0ZDEzYWI2ODhmNDZmYTQyODI4OCIsInBhdGgiOiIvYXBpL2ltYWdlL3NlcnZlL2ViOGIzZTJhMjZhNTIyNjQ5MzNjNjI3NWZjNWJkNDE5L29yaWdpbmFsIiwicGFyYW1zIjpbXSwiaWF0IjoxNzU0MjI1MjMwLCJleHAiOjE3NTQzMTE2MzB9.nxJLBE_sHBA30KbHNBCzILcYtWVbD4HPMKNpI9rWYsQ\"\n           width=\"48\" \n           height=\"48\" \n           class=\"align-middle\">\n    </a>\n  </div>\n</div>\n",
