                            "template": "{% set selected = states('input_select.selected_server') | lower %} [\n  {% for e in states.input_button\n       if e.entity_id.startswith('input_button.player_' + selected + '_')\n       and e.state != 'unavailable'\n       and not e.attributes.get('removed', false) %}\n    {\n      \"type\": \"custom:button-card\",\n      \"show_icon\": {{false}},\n      \"entity\": \"{{ e.entity_id }}\",\n      \"name\": \"{{ (e.attributes.friendly_name or e.entity_id).split(' - ', 1)[1] if ' - ' in (e.attributes.friendly_name or '') else (e.attributes.friendly_name or e.entity_id) }}\",\n      \"tap_action\": {\n        \"action\": \"call-service\",\n        \"service\": \"input_button.press\",\n        \"service_data\": {\n          \"entity_id\": \"{{ e.entity_id }}\"\n        }\n      },\n      \"card_mod\": {\n        \"style\": \"ha-card {backdrop-filter: none !important; -webkit-backdrop-filter: none !important; background: rgba(0,0,0,0); border: none !important; box-shadow: none !important; min-height: 28px; height: 32px;{% if loop.last %} margin-bottom: 0px;{% endif %}} .ellipsis{font-size:20px;font-weight:900}\"\n      }\n    },\n  {% endfor %}\n]"
                          },
