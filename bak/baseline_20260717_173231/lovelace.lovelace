                    {
                      "type": "conditional",
                      "conditions": [
                        {
                          "entity": "input_select.info_square_tab",
                          "state": "ADM预告"
                        }
                      ],
                      "card": {
                        "type": "custom:mod-card",
                        "card_mod": {
                          "style": "ha-card {\n  box-shadow: none !important;\n}\n"
                        },
                        "card": {
                          "entity": "",
                          "content": "<div class=\"flex flex-col\">\n  <!-- 标题区域 - 增大一个号 -->\n  <h1 class=\"text-3xl font-bold text-left mb-0 m-0\">ADM预告</h1>\n  \n  <!-- ADM内容区域 -->\n  <div class=\"adm-container\">\n    {% set cards = state_attr('sensor.adm_preview_full', 'cards') %}\n    {% if cards %}\n      {% for card in cards %}\n        {% if card.type == 'markdown' %}\n          {% if not loop.first %}\n            <!-- 分隔线 - 模拟markdown --- 样式 -->\n            <hr class=\"border-0 h-px mb-0 my-4 mx-0\">\n          {% endif %}\n          <div class=\"prose max-w-none text-left mb-4 leading-relaxed break-all whitespace-pre-line\">\n            {{ card.content | safe }}\n          </div>\n        {% elif card.type == 'iframe' %}\n          <div class=\"mb-4 rounded-xl overflow-hidden\">\n            <iframe \n              src=\"{{ card.url }}\" \n              class=\"w-full aspect-video min-h-[200px] max-h-[400px] border-0 rounded-xl\"\n              frameborder=\"0\"\n              allowfullscreen>\n            </iframe>\n          </div>\n        {% elif card.type == 'picture' %}\n          <div class=\"text-center my-2 w-full relative z-[1]\">\n            <a href=\"{{ card.tap_action.url_path or '#' }}\" \n               target=\"_blank\" \n               class=\"block w-full relative z-[999] no-underline hover:opacity-80 transition-opacity duration-200\"\n               onclick=\"event.stopPropagation(); window.open('{{ card.tap_action.url_path or '#' }}', '_blank'); return false;\">\n              <img src=\"{{ card.image }}\" \n                   alt=\"ADM图片\"\n                   class=\"w-full h-auto {% if card.tap_action.url_path == card.image %}border-0{% else %}border-2 border-blue-500{% endif %} rounded-lg shadow-sm cursor-pointer block relative z-[999] transition-opacity duration-200\">\n            </a>\n          </div>\n        {% endif %}\n      {% endfor %}\n    {% else %}\n      <!-- 如果没有cards属性，回退到原来的content显示方式 -->\n      <div class=\"prose max-w-none text-left mb-4 leading-relaxed break-all whitespace-pre-line\">\n        {{ state_attr('sensor.adm_preview_full', 'content') | safe }}\n      </div>\n    {% endif %}\n  \n  \n  </div>\n\n  <!-- 最后的分隔线 - 增大间距 -->\n  <hr class=\"border-0 h-px mb-6 mx-0\" />\n  \n  <!-- 底部链接图标（可选：ADM频道入口） -->\n  <div class=\"text-center -mt-2\">\n    <a href=\"https://discord.com/channels/1219676794840547388/1219684258298200224\" \n       target=\"_blank\" \n       class=\"inline-block\">\n      <img src=\"https://hass.whiterober.com/api/image/serve/eb8b3e2a26a52264933c6275fc5bd419/original\"\n           width=\"48\" \n           height=\"48\" \n           class=\"align-middle\">\n    </a>\n  </div>\n</div>\n",
                          "ignore_line_breaks": true,
                          "always_update": false,
                          "parse_jinja": true,
                          "code_editor": "Ace",
                          "entities": [],
                          "bindings": [],
                          "actions": [],
                          "debounceChangePeriod": 100,
                          "plugins": {
                            "daisyui": {
                              "enabled": true,
                              "url": "https://cdn.jsdelivr.net/npm/daisyui@latest/dist/full.css",
                              "theme": "dark - dark",
                              "overrideCardBackground": false
                            },
                            "tailwindElements": {
                              "enabled": false
                            }
                          },
                          "type": "custom:tailwindcss-template-card",
                          "card_mod": {
                            "style": "ha-card {\n  box-shadow: none !important;\n  padding: 18px !important;\n}\n\n/* 重写字体大小以匹配markdown卡片 */\nha-card .prose,\nha-card .prose p,\nha-card .prose div,\nha-card .prose span {\n  font-size: inherit !important;\n  font-family: inherit !important;\n}\n\n/* 确保继承 markdown 卡片的基础字体 */\nha-card {\n  font-size: var(--paper-font-body1_-_font-size, 14px) !important;\n  font-family: var(--paper-font-body1_-_font-family, 'Roboto', sans-serif) !important;\n}\n\n/* h3 标签继承默认的h3字号，不覆盖字体大小 */\nha-card h3,\nha-card .prose h3 {\n  font-family: inherit !important;\n  font-weight: bold !important;\n  margin: 0 !important;\n  color: var(--primary-text-color) !important;\n  line-height: 1.3 !important;\n  font-size: 1.17em;\n}\n\nha-card p,\nha-card .prose p {\n  margin:-3px 0px !important;\n  line-height: 1.3em !important; \n  padding-left: 0px;\n  text-indent: -0px;\n  position: relative;\n  padding-left: 1.2em;\n}\n\nha-card span,\nha-card .prose span {\n  position: relative !important;\n  display: inline-block !important;\n  #margin-bottom: 0.8em !important;\n  vertical-align: top;\n  text-align: center !important;\n}\n\nha-card sub,\nha-card .prose sub {\n  display: block !important;\n  font-size: 0.7em !important;\n  max-width: 1080px !important;\n  word-break: break-all !important;\n  width: 100% !important;\n  text-align: center !important;\n  margin: 0 !important;\n  padding: 0 !important;\n  padding-left: 0px !important;\n  margin-bottom: 0.8em !important;\n  #vertical-align: sub;\n}\n\np::before {\n  content: \"▪\";\n  position: absolute;\n  left: 0;\n  top: 0;\n  width: 1em;\n  text-align: center;\n}\n\n/* 确保分隔线样式与markdown一致 */\nha-card hr {\n  border: none !important;\n  border-top: 1px solid !important;\n  height: 1px !important;\n  border-color: var(--divider-color) !important;\n}\n\nha-card .prose,\nha-card .prose p,\nha-card .prose div,\nha-card .prose span {\n  user-select: text !important;\n}\n"
