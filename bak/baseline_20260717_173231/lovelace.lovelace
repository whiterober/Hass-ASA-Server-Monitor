                        "card": {
                          "entity": "",
                          "content": "<div class=\"flex flex-col\">\n  <!-- 完整合并表格 -->\n  <div class=\"borderr relative overflow-auto border border-gray-300\">\n    <table id=\"supply-table\" class=\"table-fixed border-collapse w-full min-w-max\">\n      <thead class=\"sticky top-0 z-20\">\n        <tr>\n          <th\n            class=\"sticky left-0 z-30 border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            补给品\n          </th>\n          <th\n            class=\"border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            <label class=\"col-head\" title=\"切换：隐藏该列中的空行\">\n              <input type=\"checkbox\" class=\"col-toggle\" hidden />\n              <ha-icon icon=\"mdi:island\"></ha-icon> 孤岛\n            </label>\n          </th>\n          <th\n            class=\"border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            <label class=\"col-head\" title=\"切换：隐藏该列中的空行\">\n              <input type=\"checkbox\" class=\"col-toggle\" hidden />\n              <ha-icon icon=\"mdi:earth\"></ha-icon> 核心岛\n            </label>\n          </th>\n          <th\n            class=\"border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            <label class=\"col-head\" title=\"切换：隐藏该列中的空行\">\n              <input type=\"checkbox\" class=\"col-toggle\" hidden />\n              <ha-icon icon=\"mdi:fire\"></ha-icon> 焦土\n            </label>\n          </th>\n          <th\n            class=\"border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            <label class=\"col-head\" title=\"切换：隐藏该列中的空行\">\n              <input type=\"checkbox\" class=\"col-toggle\" hidden />\n              <ha-icon icon=\"mdi:mushroom\"></ha-icon> 畸变\n            </label>\n          </th>\n          <th\n            class=\"border border-gray-300 p-2 text-center whitespace-nowrap\"\n          >\n            <label class=\"col-head\" title=\"切换：隐藏该列中的空行\">\n           