msgctxt "GraphLiteral/3310800977"
msgid ""
"import os, re\n"
"\n"
"exts = [\"BMP\", \"EXR\", \"PNG\", \"JPG\", \"TGA\", \"DDS\"]\n"
"lookups = {\"BC$\":'BC',\n"
"           \"BaseColor$\":'BC',           \n"
"           \"D$\":'BC',          \n"
"           \"Diffuse$\":'BC',\n"
"           \"N$\":'N',\n"
"           \"Normal$\":'N',\n"
"           \"L$\":'L',\n"
"           \"Layered$\":\"L\",\n"
"           \"E$\":\"E\",\n"
"           \"Emissive$\":\"E\"}\n"
"\n"
"#filename\n"
"folder = os.path.dirname(file_name)\n"
"basename = os.path.basename(file_name).split('.')[0]\n"
"files = os.listdir(folder)\n"
"\n"
"textures = {}\n"
"for key in lookups.keys():\n"
"    if re.findall(f'_{key}', basename):\n"
"        basename = re.sub(f'_{key}', '', basename, "
"re.IGNORECASE)\n"
"\n"
"all_textures = {}\n"
"for item in files:\n"
"    #print(item)\n"
"    #print(f' - image file: {item.split(\".\")[-1].upper() in exts}')\n"
"    if item.split('.')[-1].upper() in exts:\n"
"        for k,v in lookups.items():            \n"
"            #print(f\" - matches basename: "
"{bool(re.findall(f'{basename}_{k}', item.split('.')[0]))}\")\n"
"            if re.findall(f'{basename}_{k}', item.split('.')[0]):\n"
"                textures[v] = f'{folder}/{item}'\n"
"\n"
"base_color = textures.get('BC', '')\n"
"normal = textures.get('N', '')\n"
"layered = textures.get('L', '')\n"
"emissive = textures.get('E', '')\n"
"\n"
"for k in list(lookups.keys()) + ['^T_', '^MI_', '^MM_', '^M_']:\n"
"    basename = re.sub(k,'', basename, re.IGNORECASE)\n"
"material_name = f\"MI_{basename}\"\n"
"\n"
"print(f'MaterialName {material_name}')\n"
"print(f'BaseColor {base_color}')\n"
"print(f'Normal {normal}')\n"
"print(f'Layered {layered}')\n"
"print(f'Emissive {emissive}')\n"
"\n"
msgstr ""

