msgstr ""

msgctxt "GraphLiteral/3729440138"
msgid "Helena:  I’m sorry Meeka, I’m not."
msgstr ""

msgctxt "GraphLiteral/2461610786"
msgid "Helena:  See? You DO know more than you think."
