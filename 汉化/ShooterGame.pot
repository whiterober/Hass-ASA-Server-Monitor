msgctxt "GraphLiteral/1745385375"
msgid ""
"import re, os\n"
"regex = re.compile('_Rig\\.[a-zA-Z0-9\\.]+$', re.IGNORECASE)\n"
"result = bool(re.findall(regex, str(name)))\n"
"rig_path = str(name)\n"
"static_path = ''\n"
"\n"
"if result:\n"
"    static_path = rig_path\n"
"    # print(f'static_path before: {static_path}')\n"
"    for x in re.findall(regex, static_path):\n"
"        static_path = re.sub(x, '.fbx', static_path)\n"
"    # print(f'static_path after: {static_path}')\n"
"\n"
"elif bool(rig_path):\n"
"    static_path = rig_path\n"
"    folder = os.path.dirname(rig_path)\n"
"    check_rig_path = "
"f'{folder}/{os.path.basename(rig_path).split(\".\")[0]}_Rig.fbx'\n"
"    rig_path = ''\n"
"    for item in os.listdir(folder):\n"
"        test_path = f'{folder}/{str(item)}'\n"
"        # print(f'{test_path.lower() == check_rig_path.lower()}')\n"
"        # print (f' {test_path}')\n"
"        # print (f' {check_rig_path}')\n"
"        if test_path.lower() == check_rig_path.lower():\n"
"            rig_path = test_path\n"
"            result = True\n"
"            break\n"
"\n"
"\n"
"# print(f'Is Rig         : {result}')\n"
"# print(f' - in file     : {str(name)}')\n"
"# print(f' - rig_path    : {rig_path}')\n"
"# print(f' - static_path : {static_path}')"
msgstr ""

