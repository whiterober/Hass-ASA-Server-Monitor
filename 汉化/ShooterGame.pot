"import json, os, datetime;\n"
"\n"
"fpn_json_out = fpn_json;\n"
"list_instance_transforms = instance_transforms.split('&');\n"
"\n"
"D = {};\n"
"\n"
"D['datetime'] = str(datetime.datetime.now());\n"
"D['username'] = os.getenv('username');\n"
"D['fpn_json'] = fpn_json;\n"
"D['level_instance_name'] = linst_name;\n"
"D['level_instance_ref'] = linst_path_reference;\n"
"\n"
"list_components = []\n"
"\n"
"for i in range(len(component_type)):\n"
"    C = {};\n"
"    C['component_type'] = component_type[i];\n"
"    C['sm_path_reference'] = sm_path_reference[i];\n"
"    C['sm_path_source'] = sm_path_source[i];\n"
"    C['component_transform'] = str(component_transform[i]);\n"
"\n"
"    list_split_instance_transforms = "
"list_instance_transforms[i].split(',');\n"
"    list_clean_instance_transforms = [];\n"
"    for j in range(len(list_split_instance_transforms)):\n"
"        j_clean = list_split_instance_transforms[j].replace('[','');\n"
"        j_clean = j_clean.replace(']','');\n"
"        if j_clean != ' ' and j_clean != '':\n"
"            #list_split_instance_transforms[j] = j_clean;\n"
"            list_clean_instance_transforms.append(j_clean);\n"
"    C['instance_transforms'] = list_clean_instance_transforms;\n"
"    list_components.append(C);\n"
"\n"
"D['components'] = "
"list_components;\n"
"\n"
"#print(D);\n"
"#print(\"=================\");\n"
"#print(instance_transforms)\n"
"\n"
"if not os.path.isdir(os.path.dirname(fpn_json)):\n"
"    os.makedirs(os.path.dirname(fpn_json));\n"
"\n"
"with open(fpn_json, 'w', encoding='utf-8') as f:\n"
"    json.dump(D, f, ensure_ascii=False, "
"indent=4)\n"
"\n"
"print(len(component_type))"
msgstr ""

